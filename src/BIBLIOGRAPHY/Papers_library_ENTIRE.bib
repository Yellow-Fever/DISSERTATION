@article{Beasley:2004ju,
author = {Beasley, David W C and Li, Li and Suderman, Miguel T and Guirakhoo, Farshad and Trent, Dennis W and Monath, Thomas P and Shope, Robert E and Barrett, Alan D T},
title = {{Protection against Japanese encephalitis virus strains representing four genotypes by passive transfer of sera raised against ChimeriVax-JE experimental vaccine.}},
