@article{Ng:2006be,
author = {Ng, Dominic Chi Hiung and Lin, Bao Hong and Lim, Cheh Peng and Huang, Guochang and Zhang, Tong and Poli, Valeria and Cao, Xinmin},
title = {{Stat3 regulates microtubules by antagonizing the depolymerization activity of stathmin.}},
journal = {The Journal of cell biology},
year = {2006},
volume = {172},
number = {2},
pages = {245--257},
month = jan,
affiliation = {Signal Transduction Laboratory, Institute of Molecular and Cell Biology, Singapore 138673, Republic of Singapore.},
doi = {10.1083/jcb.200503021},
pmid = {16401721},
pmcid = {PMC2063554},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-05-14T18:15:53GMT+00:00},
date-modified = {2015-10-14T22:30:16GMT+00:00},
abstract = {Stat3 is a member of the signal transducer and activator of transcription family, which is important in cytokine signaling. Gene ablation studies have revealed a requirement for Stat3 in diverse biological processes (Akira, S. 2000. Oncogene. 19: 2607-2611; Levy, D.E., and C.K. Lee. 2002. J. Clin. Invest. 109:1143-1148). Previously, the function of Stat3 had been attributed exclusively to its transcriptional activity in the nucleus. In this study, we reveal an interaction between Stat3 and the microtubule (MT)-destabilizing protein stathmin. Stathmin did not overtly affect ligand-stimulated Stat3 activation. In contrast, the expression of Stat3 is required for the stabilization of MTs and cell migration. We further demonstrate that Stat3-containing cells are resistant to the MT-destabilizing effect of stathmin overexpression. In addition, down-regulation of stathmin protein levels in Stat3-deficient cells partially reversed the MT and migration deficiencies. Recombinant Stat3 was also capable of reversing stathmin inhibition of tubulin polymerization in vitro. Our results indicate that Stat3 modulates the MT network by binding to the COOH-terminal tubulin-interacting domain of stathmin and antagonizing its MT destabilization activity.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=16401721&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2006/Ng/J._Cell_Biol._2006_Ng.pdf},
file = {{J._Cell_Biol._2006_Ng.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2006/Ng/J._Cell_Biol._2006_Ng.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1083/jcb.200503021}}
}

@article{Tan:2007vr,
