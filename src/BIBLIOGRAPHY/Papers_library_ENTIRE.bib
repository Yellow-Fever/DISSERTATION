@article{Wu:2015ex,
author = {Wu, Hongmei and Bock, Stefanie and Snitko, Mariya and Berger, Thilo and Weidner, Thomas and Holloway, Steven and Kanitz, Manuel and Diederich, Wibke E and Steuber, Holger and Walter, Christof and Hofmann, Daniela and Wei{\ss}brich, Benedikt and Spannaus, Ralf and Acosta, Eliana G and Bartenschlager, Ralf and Engels, Bernd and Schirmeister, Tanja and Bodem, Jochen},
