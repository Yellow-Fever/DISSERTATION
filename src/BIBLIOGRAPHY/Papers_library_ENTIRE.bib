@article{Johansson:2014hv,
author = {Johansson, Michael A and Vasconcelos, Pedro F C and Staples, J Erin},
title = {{The whole iceberg: estimating the incidence of yellow fever virus infection from the number of severe cases.}},
journal = {Transactions of the Royal Society of Tropical Medicine and Hygiene},
year = {2014},
volume = {108},
number = {8},
pages = {482--487},
month = aug,
affiliation = {Division of Vector-Borne Diseases, Centers for Disease Control {\&} Prevention, Fort Collins, Colorado, USA mjohansson@cdc.gov.},
doi = {10.1093/trstmh/tru092},
pmid = {24980556},
language = {English},
read = {Yes},
rating = {0},
date-added = {2015-03-05T03:02:18GMT+00:00},
date-modified = {2015-10-14T22:30:17GMT+00:00},
abstract = {BACKGROUND:Like many infectious agents, yellow fever (YF) virus only causes disease in a proportion of individuals it infects and severe illness only represents the tip of the iceberg relative to the total number of infections, the more critical factor for virus transmission.

METHODS:We compiled data on asymptomatic infections, mild disease, severe disease (fever with jaundice or hemorrhagic symptoms) and fatalities from 11 studies in Africa and South America between 1969 and 2011. We used a Bayesian model to estimate the probability of each infection outcome.

RESULTS:For YF virus infections, the probability of being asymptomatic was 0.55 (95% credible interval [CI] 0.37-0.74), mild disease 0.33 (95% CI 0.13-0.52) and severe disease 0.12 (95% CI 0.05-0.26). The probability of death for people experiencing severe disease was 0.47 (95% CI 0.31-0.62).

CONCLUSIONS:In outbreak situations where only severe cases may initially be detected, we estimated that there may be between one and seventy infections that are either asymptomatic or cause mild disease for every severe case identified. As it is generally only the most severe cases that are recognized and reported, these estimates will help improve the understanding of the burden of disease and the estimation of the potential risk of spread during YF outbreaks.},
url = {http://trstmh.oxfordjournals.org/cgi/doi/10.1093/trstmh/tru092},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2014/Johansson/Trans._R._Soc._Trop._Med._Hyg._2014_Johansson.pdf},
file = {{Trans._R._Soc._Trop._Med._Hyg._2014_Johansson.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2014/Johansson/Trans._R._Soc._Trop._Med._Hyg._2014_Johansson.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1093/trstmh/tru092}}
}

@article{Luo:2015hd,
author = {Luo, Dahai and Vasudevan, Subhash G and Lescar, Julien},
title = {{The flavivirus NS2B-NS3 protease-helicase as a target for antiviral drug development.}},
journal = {Antiviral Research},
year = {2015},
volume = {118},
pages = {148--158},
month = jun,
affiliation = {Lee Kong Chian School of Medicine, Nanyang Technological University, 61 Biopolis Drive, Proteos Building, {\#}07-03, Singapore 138673, Singapore. Electronic address: luodahai@ntu.edu.sg.},
doi = {10.1016/j.antiviral.2015.03.014},
pmid = {25842996},
language = {English},
read = {Yes},
rating = {0},
date-added = {2015-11-20T13:10:24GMT+00:00},
date-modified = {2015-11-20T14:35:56GMT+00:00},
abstract = {The flavivirus NS3 protein is associated with the endoplasmic reticulum membrane via its close interaction with the central hydrophilic region of the NS2B integral membrane protein. The multiple roles played by the NS2B-NS3 protein in the virus life cycle makes it an attractive target for antiviral drug discovery. The N-terminal region of NS3 and its cofactor NS2B constitute the protease that cleaves the viral polyprotein. The NS3 C-terminal domain possesses RNA helicase, nucleoside and RNA triphosphatase activities and is involved both in viral RNA replication and virus particle formation. In addition, NS2B-NS3 serves as a hub for the assembly of the flavivirus replication complex and also modulates viral pathogenesis and the host immune response. Here, we review biochemical and structural advances on the NS2B-NS3 protein, including the network of interactions it forms with NS5 and NS4B and highlight recent drug development efforts targeting this protein. This article forms part of a symposium in Antiviral Research on flavivirus drug discovery.},
url = {http://linkinghub.elsevier.com/retrieve/pii/S0166354215000789},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/EE/EED5C4F4-10BB-4B32-9A78-10F4E0EE406C.pdf},
file = {{EED5C4F4-10BB-4B32-9A78-10F4E0EE406C.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/EE/EED5C4F4-10BB-4B32-9A78-10F4E0EE406C.pdf:application/pdf;EED5C4F4-10BB-4B32-9A78-10F4E0EE406C.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/EE/EED5C4F4-10BB-4B32-9A78-10F4E0EE406C.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1016/j.antiviral.2015.03.014}}
}

