@article{Woodson:2011dd,
author = {Woodson, Sara E and Freiberg, Alexander N and Holbrook, Michael R},
title = {{Differential cytokine responses from primary human Kupffer cells following infection with wild-type or vaccine strain yellow fever virus.}},
journal = {Virology},
year = {2011},
volume = {412},
number = {1},
pages = {188--195},
month = mar,
affiliation = {Department of Pathology and Institute for Human Infection and Immunity, University of Texas Medical Branch, 301 University Boulevard, Galveston, TX 77550, USA.},
doi = {10.1016/j.virol.2011.01.012},
pmid = {21277609},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-04-10T20:40:53GMT+00:00},
date-modified = {2015-10-14T22:29:56GMT+00:00},
abstract = {Wild-type yellow fever virus (YFV) infections result in a hepatotropic disease which is often fatal, while vaccination with the live-attenuated 17-D strain results in productive infection yet is well-tolerated with few adverse events. Kupffer cells (KCs) are resident liver macrophages that have a significant role in pathogen detection, clearance and immune signaling. Although KCs appear to be an important component of YF disease, their role has been under-studied. This study examined cytokine responses in KCs following infection with either wild-type or vaccine strains of YFV. Results indicate that KCs support replication of both wild-type and vaccine strains, yet wild-type YFV induced a prominent and prolonged pro-inflammatory cytokine response (IL-8, TNF-$\alpha$ and RANTES/CCL5) with little control by a major anti-inflammatory cytokine (IL-10). This response was significantly reduced in vaccine strain infections. These data suggest that a differentially regulated infection in KCs may play a critical role in development of disease.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=21277609&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2011/Woodson/Virology_2011_Woodson.pdf},
file = {{Virology_2011_Woodson.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2011/Woodson/Virology_2011_Woodson.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1016/j.virol.2011.01.012}}
}

