@article{Chawla:2001ul,
author = {Chawla, A and Boisvert, W A and Lee, C H and Laffitte, B A and Barak, Y and Joseph, S B and Liao, D and Nagy, L and Edwards, P A and Curtiss, L K and Evans, R M and Tontonoz, P},
title = {{A PPAR gamma-LXR-ABCA1 pathway in macrophages is involved in cholesterol efflux and atherogenesis.}},
journal = {Molecular cell},
year = {2001},
volume = {7},
number = {1},
pages = {161--171},
month = jan,
affiliation = {Salk Institute for Biological Studies, Howard Hughes Medical Institute, La Jolla, CA 92037, USA.},
pmid = {11172721},
language = {English},
rating = {0},
date-added = {2012-05-18T20:38:20GMT+00:00},
date-modified = {2015-10-14T22:29:19GMT+00:00},
abstract = {Previous work has implicated PPAR gamma in the regulation of CD36 expression and macrophage uptake of oxidized LDL (oxLDL). We provide evidence here that in addition to lipid uptake, PPAR gamma regulates a pathway of cholesterol efflux. PPAR gamma induces ABCA1 expression and cholesterol removal from macrophages through a transcriptional cascade mediated by the nuclear receptor LXR alpha. Ligand activation of PPAR gamma leads to primary induction of LXR alpha and to coupled induction of ABCA1. Transplantation of PPAR gamma null bone marrow into LDLR -/- mice results in a significant increase in atherosclerosis, consistent with the hypothesis that regulation of LXR alpha and ABCA1 expression is protective in vivo. Thus, we propose that PPAR gamma coordinates a complex physiologic response to oxLDL that involves particle uptake, processing, and cholesterol removal through ABCA1.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=11172721&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2001/Chawla/Mol._Cell_2001_Chawla.pdf},
file = {{Mol._Cell_2001_Chawla.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2001/Chawla/Mol._Cell_2001_Chawla.pdf:application/pdf}},
uri = {\url{papers3://publication/uuid/7261C135-5545-4771-860B-3536A3329DC9}}
