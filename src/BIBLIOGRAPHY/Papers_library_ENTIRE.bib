@article{Naugler:2007bz,
author = {Naugler, Willscott E and Sakurai, Toshiharu and Kim, Sunhwa and Maeda, Shin and Kim, Kyounghyun and Elsharkawy, Ahmed M and Karin, Michael},
title = {{Gender disparity in liver cancer due to sex differences in MyD88-dependent IL-6 production.}},
journal = {Science (New York, N.Y.)},
year = {2007},
volume = {317},
number = {5834},
pages = {121--124},
month = jul,
affiliation = {Laboratory of Gene Regulation and Signal Transduction, Department of Pharmacology and Cancer Center, University of California, San Diego, CA 93093, USA.},
doi = {10.1126/science.1140485},
pmid = {17615358},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-05-04T19:27:35GMT+00:00},
date-modified = {2015-10-14T22:30:24GMT+00:00},
abstract = {Hepatocellular carcinoma (HCC), the most common liver cancer, occurs mainly in men. Similar gender disparity is seen in mice given a chemical carcinogen, diethylnitrosamine (DEN). DEN administration caused greater increases in serum interleukin-6 (IL-6) concentration in males than it did in females. Furthermore, ablation of IL-6 abolished the gender differences in hepatocarcinogenesis in mice. DEN exposure promoted production of IL-6 in Kupffer cells (KCs) in a manner dependent on the Toll-like receptor adaptor protein MyD88, ablation of which also protected male mice from DEN-induced hepatocarcinogenesis. Estrogen inhibited secretion of IL-6 from KCs exposed to necrotic hepatocytes and reduced circulating concentrations of IL-6 in DEN-treated male mice. We propose that estrogen-mediated inhibition of IL-6 production by KCs reduces liver cancer risk in females, and these findings may be used to prevent HCC in males.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=17615358&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2007/Naugler/Science_2007_Naugler.pdf},
file = {{Science_2007_Naugler.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2007/Naugler/Science_2007_Naugler.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1126/science.1140485}}
}

@article{Ahmed:2011by,
author = {Ahmed, Rafi and Akondy, Rama S},
title = {{Insights into human CD8(+) T-cell memory using the yellow fever and smallpox vaccines.}},
journal = {Immunology and cell biology},
year = {2011},
volume = {89},
number = {3},
pages = {340--345},
month = mar,
affiliation = {Emory Vaccine Center, Emory University, 1462 Clifton Road, Atlanta, GA, 30322, USA.},
doi = {10.1038/icb.2010.155},
pmid = {21301482},
language = {English},
rating = {0},
date-added = {2012-04-05T20:22:05GMT+00:00},
date-modified = {2015-10-14T22:30:24GMT+00:00},
abstract = {Live virus vaccines provide a unique opportunity to study human CD8(+) T-cell memory in the context of a controlled, primary acute viral infection. Yellow fever virus-17D and Dryvax are two such live-virus vaccines that are highly efficacious, used worldwide and provide long-term immunity against yellow fever and smallpox respectively. In this review, we describe the properties of virus-specific memory CD8(+) T cells generated in smallpox and yellow fever vaccinees. We address fundamental questions regarding magnitude, functional quality and longevity of the CD8(+) T-cell response, which are otherwise challenging to address in humans. These findings provide insights into the attributes of the human immune system as well as provide a benchmark for the optimal quality of a CD8(+) T-cell response that can be used to evaluate novel candidate vaccines.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=21301482&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/doi/10.1038/icb.2010.155}}
}

