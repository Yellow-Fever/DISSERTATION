date-modified = {2015-10-14T22:29:01GMT+00:00},
abstract = {Antibody-dependent enhancement of yellow fever virus neurovirulence, as measured by a reduction in the average survival time of groups of mice, was demonstrated with wild-type or vaccine strains of yellow fever virus and with Japanese encephalitis virus using intraperitoneally administered monoclonal antibodies specific for the viral E glycoprotein of yellow fever virus. Enhancement of virulence could be induced by neutralizing, non-neutralizing or protective antibodies if the virus was allowed to establish a productive infection in the mouse brain before the antibody was administered. The implications of antibody-dependent enhancement in flaviviruses are discussed.},
