@article{Do:2015kv,
author = {Do, Loan Phuong and Bui, Trang Minh and Hasebe, Futoshi and Morita, Kouichi and Phan, Nga Thi},
title = {{Molecular epidemiology of Japanese encephalitis in northern Vietnam, 1964-2011: genotype replacement.}},
journal = {Virology Journal},
year = {2015},
volume = {12},
number = {1},
pages = {51},
publisher = {BioMed Central Ltd},
affiliation = {National Institute of Hygiene and Epidemiology, Hanoi, 10000, Vietnam. loankobe@gmail.com.},
doi = {10.1186/s12985-015-0278-4},
pmid = {25889499},
pmcid = {PMC4417254},
language = {English},
read = {Yes},
rating = {0},
date-added = {2015-09-08T17:24:21GMT+00:00},
date-modified = {2015-10-14T22:32:34GMT+00:00},
abstract = {BACKGROUND:Japanese encephalitis virus (JEV) is an arthropod-borne virus causing serious public health issues in Asia. JEV consists of five genotypes and recent studies have shown the emergence of JEV genotype I (GI) and its replacement of genotype III (GIII). Using an archival JEV collection, we investigated the molecular evolution of JEV in Vietnam over the last 48~years (1964-2012) in humans, mosquitoes, and pigs, within the global context.

METHODS:The nine JEV isolates from humans, pigs, and mosquitoes sequenced in this study and 29 sequences available in GenBank were used to analyze the envelope (E) protein of the Vietnamese JEVs. A collection of 225 cerebrospinal fluid specimens from patients with suspected Japanese encephalitis (JE) was also tested and genotyped with real-time RT-PCR.

RESULTS:The 38 E genes identified with sequencing and nine Vietnamese JEV strains genotyped with real-time RT-PCR, belonging to two lineages, evolved in accordance with those in the rest of the world. The first GIII strain was detected in humans in Vietnam in 1964, and in mosquitoes in 1979, whereas GI strains were first detected in humans and mosquitoes in 1990 and 1994, respectively. After 2004, GI was the only genotype detected in Vietnam, demonstrating that the GIIII strains had been displaced by GI strains. Five haplotypes were identified in the Vietnamese JEVs, with SKSS predominant. The S123N and S123R substitutions in the E protein were already present in the Vietnamese JEVs.

CONCLUSION:This study describes the long evolutionary history of JEV in Vietnam over 34~years, which correlates well with the global evolution of JEV. The Vietnamese GIII strains have been replaced by GI strains in mosquitoes, pigs, and humans. The predominant haplotypes of the Vietnamese strains support this genotype displacement in Vietnam. Further surveillance is required to confirm the disappearance of the GIII strains in nature and the emergence of new pathogens causing encephalitis in Vietnam, after the long-term use of JEV vaccines in that country.},
url = {http://www.virologyj.com/content/12/1/51},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/D2/D2CBD059-2867-44DC-9A40-FB74F02CE176.pdf},
file = {{D2CBD059-2867-44DC-9A40-FB74F02CE176.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/D2/D2CBD059-2867-44DC-9A40-FB74F02CE176.pdf:application/pdf;D2CBD059-2867-44DC-9A40-FB74F02CE176.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/D2/D2CBD059-2867-44DC-9A40-FB74F02CE176.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1186/s12985-015-0278-4}}
}

