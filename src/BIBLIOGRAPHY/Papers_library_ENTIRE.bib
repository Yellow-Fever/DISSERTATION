@article{Wimberly:2013kr,
author = {Wimberly, Michael and Giacomo, Paolla and Kightlinger, Lon and Hildreth, Michael},
title = {{Spatio-Temporal Epidemiology of Human West Nile Virus Disease in South Dakota}},
journal = {International Journal of Environmental Research and Public Health},
year = {2013},
volume = {10},
number = {11},
pages = {5584--5602},
month = nov,
publisher = {Multidisciplinary Digital Publishing Institute},
doi = {10.3390/ijerph10115584},
language = {English},
read = {Yes},
rating = {0},
date-added = {2015-03-26T13:26:59GMT+00:00},
date-modified = {2015-10-14T22:29:17GMT+00:00},
abstract = {Despite a cold temperate climate and low human population density, the

Northern Great Plains has become a persistent hot spot for human West Nile virus (WNV)

disease in North America. Understanding the spatial and temporal patterns of WNV can

provide insights into the epidemiological and ecological factors that influence disease

emergence and persistence. We analyzed the 1,962 cases of human WNV disease that

occurred in South Dakota from 2002{\textendash}2012 to identify the geographic distribution, seasonal

cycles, and interannual variability of disease risk. The geographic and seasonal patterns of

WNV have changed since the invasion and initial epidemic in 2002{\textendash}2003, with cases

shifting toward the eastern portion of South Dakota and occurring earlier in the

transmission season in more recent years. WNV cases were temporally autocorrelated at

lags of up to six weeks and early season cumulative case numbers were correlated with

seasonal totals, indicating the possibility of using these data for short-term early detection

of outbreaks. Epidemiological data are likely to be most effective for early warning of

WNV virus outbreaks if they are integrated with entomological surveillance and

environmental monitoring to leverage the strengths and minimize the weaknesses of each

information source.},
url = {http://www.mdpi.com/1660-4601/10/11/5584/},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/39/3952D77A-37E9-48CA-9CD7-7DF87948ACBF.pdf},
file = {{3952D77A-37E9-48CA-9CD7-7DF87948ACBF.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/39/3952D77A-37E9-48CA-9CD7-7DF87948ACBF.pdf:application/pdf;3952D77A-37E9-48CA-9CD7-7DF87948ACBF.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/39/3952D77A-37E9-48CA-9CD7-7DF87948ACBF.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.3390/ijerph10115584}}
}

