@article{Fu:2011bf,
author = {Fu, Qiang and Huang, Xiao and Shu, Bin and Xue, Mei and Zhang, Pinghu and Wang, Tao and Liu, Li and Jiang, Zhenzhou and Zhang, Luyong},
