@article{McAllister:2000up,
author = {McAllister, A and Arbetman, A E and Mandl, S and Pe{\~n}a-Rossi, C and Andino, R},
title = {{Recombinant yellow fever viruses are effective therapeutic vaccines for treatment of murine experimental solid tumors and pulmonary metastases.}},
journal = {Journal of Virology},
year = {2000},
volume = {74},
number = {19},
pages = {9197--9205},
month = oct,
affiliation = {Department of Microbiology and Immunology, University of California, San Francisco, California 94143-0414, USA.},
pmid = {10982366},
pmcid = {PMC102118},
language = {English},
read = {Yes},
rating = {0},
date-added = {2014-06-10T20:47:27GMT+00:00},
date-modified = {2015-10-14T22:29:32GMT+00:00},
abstract = {We have genetically engineered an attenuated yellow fever (YF) virus to carry and express foreign antigenic sequences and evaluated the potential of this type of recombinant virus to serve as a safe and effective tumor vaccine. Live-attenuated YF vaccine is one of the most effective viral vaccines available today. Important advantages include its ability to induce long-lasting immunity, its safety, its affordability, and its documented efficacy. In this study, recombinant live-attenuated (strain 17D) YF viruses were constructed to express a cytotoxic T-lymphocyte epitope derived from chicken ovalbumin (SIINFEKL). These recombinant viruses replicated comparably to the 17D vaccine strain in cell culture and stably expressed the ovalbumin antigen, and infected cells presented the antigen in the context of major histocompatibility complex class I. Inoculation of mice with recombinant YF virus elicited SIINFEKL-specific CD8(+) lymphocytes and induced protective immunity against challenge with lethal doses of malignant melanoma cells expressing ovalbumin. Furthermore, active immunotherapy with recombinant YF viruses induced regression of established solid tumors and pulmonary metastases. Thus, recombinant YF viruses are attractive viral vaccine vector candidates for the development of therapeutic anticancer vaccines.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=10982366&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2000/McAllister/Journal_of_Virology_2000_McAllister.pdf},
file = {{Journal_of_Virology_2000_McAllister.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2000/McAllister/Journal_of_Virology_2000_McAllister.pdf:application/pdf}},
uri = {\url{papers3://publication/uuid/3C32D802-17A2-4990-9775-73F440527658}}
}

@article{Miller:2010iu,
author = {Miller, Simon and Tavshanjian, Brandon and Oleksy, Arkadiusz and Perisic, Olga and Houseman, Benjamin T and Shokat, Kevan M and Williams, Roger L},
title = {{Shaping development of autophagy inhibitors with the structure of the lipid kinase Vps34.}},
journal = {Science (New York, N.Y.)},
year = {2010},
volume = {327},
number = {5973},
pages = {1638--1642},
month = mar,
affiliation = {Medical Research Council Laboratory of Molecular Biology, Hills Road, Cambridge CB2 0QH, UK.},
doi = {10.1126/science.1184429},
pmid = {20339072},
pmcid = {PMC2860105},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-05-04T19:43:39GMT+00:00},
date-modified = {2015-10-14T22:29:32GMT+00:00},
abstract = {Phosphoinositide 3-kinases (PI3Ks) are lipid kinases with diverse roles in health and disease. The primordial PI3K, Vps34, is present in all eukaryotes and has essential roles in autophagy, membrane trafficking, and cell signaling. We solved the crystal structure of Vps34 at 2.9 angstrom resolution, which revealed a constricted adenine-binding pocket, suggesting the reason that specific inhibitors of this class of PI3K have proven elusive. Both the phosphoinositide-binding loop and the carboxyl-terminal helix of Vps34 mediate catalysis on membranes and suppress futile adenosine triphosphatase cycles. Vps34 appears to alternate between a closed cytosolic form and an open form on the membrane. Structures of Vps34 complexes with a series of inhibitors reveal the reason that an autophagy inhibitor preferentially inhibits Vps34 and underpin the development of new potent and specific Vps34 inhibitors.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=20339072&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/doi/10.1126/science.1184429}}
}

