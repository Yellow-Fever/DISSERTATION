@article{Schlereth:2003vr,
author = {Schlereth, Bernd and Buonocore, Linda and Tietz, Annette and Meulen Vt, Volker ter and Rose, John K and Niewiesk, Stefan},
title = {{Successful mucosal immunization of cotton rats in the presence of measles virus-specific antibodies depends on degree of attenuation of vaccine vector and virus dose.}},
journal = {The Journal of General Virology},
year = {2003},
volume = {84},
number = {Pt 8},
pages = {2145--2151},
month = aug,
affiliation = {Institute of Virology and Immunobiology, University of Wuerzburg, Versbacher Str 7, 97078 Wuerzburg, Germany.},
pmid = {12867646},
language = {English},
rating = {0},
date-added = {2015-01-07T20:05:08GMT+00:00},
date-modified = {2015-10-14T22:30:27GMT+00:00},
abstract = {After passive transfer of measles virus (MV)-specific antibodies, vaccine-induced seroconversion and subsequent protection is inhibited in cotton rats (Sigmodon hispidus). In this system, an attenuated, recombinant vesicular stomatitis virus expressing the MV haemagglutinin (VSV-H) was found previously to induce neutralizing antibodies and protection against MV challenge after intranasal (i.n.) immunization. Here it is demonstrated that, after i.n. immunization, VSV-H is found in both lung and brain tissue in the absence of clinical signs. Intratracheal inoculation, which does not lead to infection of the brain, proved that immunization via the lung mucosa is sufficient to protect. To reduce or eliminate infection of the brain after i.n. inoculation, stepwise-attenuated VSV-H mutants with truncated cytoplasmic tails of the G protein were tested in cotton rats. A mutant with 9 aa in the G cytoplasmic tail was found at much lower levels in the brain and was protective in the absence or presence of MV-specific antibodies. A more attenuated mutant containing only 1 aa in its tail was not found in brain tissue after inoculation, but it still induced protective antibody to measles in the absence of MV-specific antibody. However, its ability to induce MV-neutralizing antibodies in the presence of passively transferred MV-specific antibodies and its protective capacity was abolished unless higher-dose immunizations were used. This study demonstrates that a lower degree of attenuation is required to be able to immunize in the presence of MV-specific antibodies.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=12867646&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2003/Schlereth/J._Gen._Virol._2003_Schlereth.pdf},
