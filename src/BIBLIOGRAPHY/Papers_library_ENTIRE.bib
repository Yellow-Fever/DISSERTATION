date-added = {2012-04-25T21:12:59GMT+00:00},
date-modified = {2015-10-14T22:29:39GMT+00:00},
abstract = {Mesenchymal stem cells (MSCs) are widely distributed throughout the body. Despite intensive studies on the immunosuppressive effect of MSCs, little is known about whether MSCs affect lymphocyte apoptosis. We investigated the effect of MSCs on the spontaneous death of lymphocytes and found that MSCs inhibit the apoptosis of splenocytes and thymocytes as well as purified T and B cells. The protective effect of MSCs was absent when lymphocytes were not in contact with MSCs, indicating that the anti-apoptotic effect is exerted through direct interaction between MSCs and lymphocytes. Interestingly, this anti-apoptotic effect could be inhibited by neutralization of IL-6. Consequently, we found that the expression of IL-6 by MSCs was augmented by contact with lymphocytes. Taken together, these results demonstrate that IL-6 plays an important role in the inhibition of lymphocyte apoptosis by MSCs.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=17678624&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2007/Xu/Biochem._Biophys._Res._Commun._2007_Xu.pdf},
file = {{Biochem._Biophys._Res._Commun._2007_Xu.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2007/Xu/Biochem._Biophys._Res._Commun._2007_Xu.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1016/j.bbrc.2007.07.052}}
}

@article{Mandl:2011co,
author = {Mandl, Judith N and Akondy, Rama and Lawson, Benton and Kozyr, Natalia and Staprans, Silvija I and Ahmed, Rafi and Feinberg, Mark B},
title = {{Distinctive TLR7 signaling, type I IFN production, and attenuated innate and adaptive immune responses to yellow fever virus in a primate reservoir host.}},
journal = {Journal of Immunology},
year = {2011},
volume = {186},
number = {11},
pages = {6406--6416},
month = jun,
affiliation = {Emory University, Atlanta, GA 30329, USA. mark_feinberg@merck.com},
doi = {10.4049/jimmunol.1001191},
pmid = {21515797},
language = {English},
rating = {0},
date-added = {2012-04-05T20:21:48GMT+00:00},
date-modified = {2015-10-14T22:29:39GMT+00:00},
abstract = {Why cross-species transmissions of zoonotic viral infections to humans are frequently associated with severe disease when viruses responsible for many zoonotic diseases appear to cause only benign infections in their reservoir hosts is unclear. Sooty mangabeys (SMs), a reservoir host for SIV, do not develop disease following SIV infection, unlike nonnatural HIV-infected human or SIV-infected rhesus macaque (RM) hosts. SIV infections of SMs are characterized by an absence of chronic immune activation, in association with significantly reduced IFN-$\alpha$ production by plasmacytoid dendritic cells (pDCs) following exposure to SIV or other defined TLR7 or TLR9 ligands. In this study, we demonstrate that SM pDCs produce significantly less IFN-$\alpha$ following ex vivo exposure to the live attenuated yellow fever virus 17D strain vaccine, a virus that we show is also recognized by TLR7, than do RM or human pDCs. Furthermore, in contrast to RMs, SMs mount limited activation of innate immune responses and adaptive T cell proliferative responses, along with only transient antiviral Ab responses, following infection with yellow fever vaccine 17D strain. However, SMs do raise significant and durable cellular and humoral immune responses comparable to those seen in RMs when infected with modified vaccinia Ankara, a virus whose immunogenicity does not require TLR7/9 recognition. Hence, differences in the pattern of TLR7 signaling and type I IFN production by pDCs between primate species play an important role in determining their ability to mount and maintain innate and adaptive immune responses to specific viruses, and they may also contribute to determining whether disease follows infection.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=21515797&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/doi/10.4049/jimmunol.1001191}}
}

