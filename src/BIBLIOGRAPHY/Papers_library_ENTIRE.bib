@article{Edupuganti:2013bw,
author = {Edupuganti, Srilatha and Eidex, Rachel B and Keyserling, Harry and Akondy, Rama S and Lanciotti, Robert and Orenstein, Walter and Del Rio, Carlos and Pan, Yi and Querec, Troy and Lipman, Harvey and Barrett, Alan and Ahmed, Rafi and Teuwen, Dirk and Cetron, Martin and Mulligan, Mark J and {YF-Ig Study Team}},
title = {{A randomized, double-blind, controlled trial of the 17D yellow fever virus vaccine given in combination with immune globulin or placebo: comparative viremia and immunogenicity.}},
journal = {The American Journal of Tropical Medicine and Hygiene},
year = {2013},
volume = {88},
number = {1},
pages = {172--177},
month = jan,
affiliation = {Department of Medicine, Emory University School of Medicine, Atlanta, Georgia, USA. sedupug@emory.edu},
doi = {10.4269/ajtmh.2012.12-0179},
pmid = {23208880},
pmcid = {PMC3541731},
language = {English},
read = {Yes},
rating = {0},
date-added = {2015-05-14T16:08:32GMT+00:00},
date-modified = {2015-10-14T22:30:18GMT+00:00},
abstract = {We evaluated whether coadministration of the yellow fever (YF) virus vaccine with human immunoglobulin (Ig) that contained YF virus-neutralizing antibodies would reduce post-vaccination viremia without compromising immunogenicity and thus, potentially mitigate YF vaccine-associated adverse events. We randomized 80 participants to receive either YF vaccine and Ig or YF vaccine and saline placebo. Participants were followed for 91 days for safety and assessments of viremia and immunogenicity. There were no differences found between the two groups in the proportion of vaccinated participants who developed viremia, seroconversion, cluster of differentiation (CD)-8(+) and CD4(+) T-cell responses, and cytokine responses. These results argue against one putative explanation for the increased reporting of YF vaccine side effects in recent years (i.e., a change in travel clinic practice after 1996 when hepatitis A prophylaxis with vaccine replaced routine use of pre-travel Ig, thus potentially removing an incidental YF vaccine-attenuating effect of anti-YF virus antibodies present in Ig).},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=23208880&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/D5/D5FC3CDE-448C-42A5-8CE9-014DC7DD3CBD.pdf},
file = {{D5FC3CDE-448C-42A5-8CE9-014DC7DD3CBD.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/D5/D5FC3CDE-448C-42A5-8CE9-014DC7DD3CBD.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.4269/ajtmh.2012.12-0179}}
}

