@article{terMeulen:2004ega,
author = {ter Meulen, Jan and Sakho, Mohamed and Koulemou, Kekoura and Magassouba, N'Faly and Bah, Aissatou and Preiser, Wolfgang and Daffis, Stephane and Klewitz, Christian and Bae, Hi-Gung and Niedrig, Matthias and Zeller, Herv{\'e} and Heinzel-Gutenbrunner, Monika and Koivogui, Lamine and Kaufmann, Andreas},
title = {{Activation of the cytokine network and unfavorable outcome in patients with yellow fever.}},
journal = {The Journal of Infectious Diseases},
year = {2004},
volume = {190},
number = {10},
pages = {1821--1827},
month = nov,
affiliation = {Department of Virology, Philipps University Marburg, Marburg, Germany. j.termeulen@crucell.com},
doi = {10.1086/425016},
pmid = {15499539},
language = {English},
rating = {0},
date-added = {2012-04-05T20:24:18GMT+00:00},
date-modified = {2015-10-14T22:29:51GMT+00:00},
abstract = {To study the contribution of inflammatory mediators to the pathogenesis of yellow fever (YF), the serum levels of several cytokines and chemokines were measured in 7 patients with fatal YF (f-YF), 11 patients with nonfatal hemorrhagic YF (nf/h-YF), and 18 patients with nonfatal nonhemorrhagic YF (nf/nh-YF). The levels of interleukin (IL)-6, monocyte chemoattractant protein-1, interferon-inducible protein (IP)-10, tumor necrosis factor- alpha , and IL-1 receptor antagonist (IL-1RA) were all statistically significantly higher in the patients with f-YF than in those with nf/nh-YF. In patients with nf/h-YF, only levels of IP-10 and IL-1RA were significantly elevated. The high levels of pro- and anti-inflammatory cytokines and chemokines in serum from patients with f-YF are reminiscent of those seen in patients with bacterial sepsis. This finding has implications for the understanding of the pathophysiology of YF and the development of therapeutic strategies.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=15499539&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/doi/10.1086/425016}}
}

@article{Mutebi:2002wr,
author = {Mutebi, John-Paul and Barrett, Alan D T},
title = {{The epidemiology of yellow fever in Africa.}},
journal = {Microbes and infection / Institut Pasteur},
year = {2002},
volume = {4},
number = {14},
pages = {1459--1468},
month = nov,
affiliation = {Center for Tropical Diseases and Department of Pathology, University of Texas Medical Branch, Galveston, TX 77555-0609, USA.},
pmid = {12475636},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-04-24T19:36:35GMT+00:00},
date-modified = {2015-10-14T22:29:51GMT+00:00},
abstract = {Yellow fever (YF) is still a major public heath problem, particularly in Africa, despite the availability of a very efficacious vaccine. The World Health Organization estimates that there are 200,000 cases of YF annually, including 30,000 deaths, of which over 90% occur in Africa. In the past 15 years, the number of YF cases has increased tremendously, with most of the YF activity in West Africa. This increase in YF activity is in part due to a breakdown in YF vaccination and mosquito control programs. Five genotypes of YF virus have been found in Africa, and each genotype circulates in a distinct geographical region. West Africa genotype I, found in Nigeria and surrounding areas, is associated with frequent epidemics, whereas the three genotypes in East and Central Africa are in regions where YF outbreaks are rare. Other factors, including genetic and behavioral variation among vector species, are also thought to play a role in the epidemiology of YF in Africa.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=12475636&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2002/Mutebi/Microbes_Infect._2002_Mutebi.pdf},
