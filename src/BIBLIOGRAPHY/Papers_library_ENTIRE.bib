@article{Singh:2012hj,
author = {Singh, Rajat and Cuervo, Ana Maria},
title = {{Lipophagy: connecting autophagy and lipid metabolism.}},
journal = {International journal of cell biology},
year = {2012},
volume = {2012},
pages = {282041},
affiliation = {Department of Medicine, Albert Einstein College of Medicine, Bronx, NY 10461, USA.},
doi = {10.1155/2012/282041},
pmid = {22536247},
pmcid = {PMC3320019},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-05-04T19:47:12GMT+00:00},
date-modified = {2015-10-14T22:28:45GMT+00:00},
abstract = {Lipid droplets (LDs), initially considered "inert" lipid deposits, have gained during the last decade the classification of cytosolic organelles due to their defined composition and the multiplicity of specific cellular functions in which they are involved. The classification of LD as organelles brings along the need for their regulated turnover and recent findings support the direct contribution of autophagy to this turnover through a process now described as lipophagy. This paper focuses on the characteristics of this new type of selective autophagy and the cellular consequences of the mobilization of intracellular lipids through this process. Lipophagy impacts the cellular energetic balance directly, through lipid breakdown and, indirectly, by regulating food intake. Defective lipophagy has been already linked to important metabolic disorders such as fatty liver, obesity and atherosclerosis, and the age-dependent decrease in autophagy could underline the basis for the metabolic syndrome of aging.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=22536247&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2012/Singh/Int_J_Cell_Biol_2012_Singh.pdf},
file = {{Int_J_Cell_Biol_2012_Singh.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2012/Singh/Int_J_Cell_Biol_2012_Singh.pdf:application/pdf;Int_J_Cell_Biol_2012_Singh.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2012/Singh/Int_J_Cell_Biol_2012_Singh.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1155/2012/282041}}
}

@article{Leung:2009bg,
author = {Leung, Kar Wah and Barnstable, Colin J and Tombran-Tink, Joyce},
title = {{Bacterial endotoxin activates retinal pigment epithelial cells and induces their degeneration through IL-6 and IL-8 autocrine signaling.}},
journal = {Molecular immunology},
year = {2009},
volume = {46},
number = {7},
pages = {1374--1386},
month = apr,
affiliation = {Department of Neural and Behavioral Sciences, Pennsylvania State University College of Medicine, Hershey, PA, USA.},
doi = {10.1016/j.molimm.2008.12.001},
pmid = {19157552},
language = {English},
rating = {0},
date-added = {2012-05-14T19:17:31GMT+00:00},
date-modified = {2015-10-14T22:28:45GMT+00:00},
abstract = {Inflammation is a major contributing factor to many blinding disorders including uveitis, diabetic retinopathy, and age-related macular degeneration. Here we examined the response of the retinal pigment epithelium (RPE) to physiological levels of lipopolysaccharide (LPS) to understand the role of this epithelium in inflammatory retinal conditions. Expression of a group of inflammatory mediators was identified by gene array analysis and confirmed by PCR and immunocytochemistry in primary human RPE cultures and ARPE19. The effects of LPS on the expression of these cytokines and RPE survival were examined by PCR, Luminex bead, and MTT assays. RPE cells express many cytokine receptors including IL-1R, -4R, -6R, -8RA, IFNAR1, IFNGR1/2 and secrete a range of pro- and anti-inflammatory cytokines including IL-4, -6, -8, -10, -17, IFN-gamma, MCP-1, and VEGF. LPS increases IL-13RA1 and IFNAR1, and decreases IL-7R receptor expression. It also increases RPE secretion of IL-4, -6, -8, -10, IFN-gamma and MCP-1, and is toxic to RPE cells at LC(50)=17.7 microg/ml. LPS toxicity is mediated by IL-6 and IL-8 through an autocrine feedback loop. Silencing IL-6R and IL-8RA gene expression by siRNA blocks death by their respective ligands or LPS. These findings imply that RPE cells are acutely sensitive to inflammatory stress and that over secretion of IL-6 and IL-8 by this epithelium during inflammatory stimulus may be an underlying factor in the progression of some retinal pathologies.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=19157552&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/doi/10.1016/j.molimm.2008.12.001}}
}

