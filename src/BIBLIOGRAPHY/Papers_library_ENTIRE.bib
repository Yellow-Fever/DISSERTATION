@article{Korbie:2008cv,
author = {Korbie, Darren J and Mattick, John S},
title = {{Touchdown PCR for increased specificity and sensitivity in PCR amplification.}},
journal = {Nature protocols},
year = {2008},
volume = {3},
number = {9},
pages = {1452--1456},
affiliation = {Australian Research Council Special Research Centre for Functional and Applied Genomics, Institute for Molecular Bioscience, University of Queensland, St Lucia, Queensland 4072, Australia.},
doi = {10.1038/nprot.2008.133},
pmid = {18772872},
language = {English},
rating = {0},
date-added = {2012-04-03T16:36:10GMT+00:00},
date-modified = {2015-10-14T22:29:28GMT+00:00},
abstract = {Touchdown (TD) PCR offers a simple and rapid means to optimize PCRs, increasing specificity, sensitivity and yield, without the need for lengthy optimizations and/or the redesigning of primers. TD-PCR employs an initial annealing temperature above the projected melting temperature (T(m)) of the primers being used, then progressively transitions to a lower, more permissive annealing temperature over the course of successive cycles. Any difference in T(m) between correct and incorrect annealing will produce an exponential advantage of twofold per cycle. TD-PCR has found wide applicability in standard PCR protocols, including reverse transcriptase-dependent PCR, as well as in the generation of cDNA libraries and single nucleotide polymorphism screening. TD-PCR is particularly useful for templates that are difficult to amplify but can also be standardly used to enhance specificity and product formation. The procedure takes between 90 and 120 min, depending on the template length.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=18772872&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2008/Korbie/Nat_Protoc_2008_Korbie.pdf},
file = {{Nat_Protoc_2008_Korbie.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2008/Korbie/Nat_Protoc_2008_Korbie.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1038/nprot.2008.133}}
}

@article{Mallimaci:2010ba,
author = {Mallimaci, Mar{\'i}a Cristina and Sosa-Estani, Sergio and Russomando, Graciela and S{\'a}nchez, Zunilda and Sijvarger, Carina and Alvarez, Isabel Marcela and Barrionuevo, Lola and Lopez, Carlos and Segura, Elsa Leonor},
title = {{Early diagnosis of congenital Trypanosoma cruzi infection, using shed acute phase antigen, in Ushuaia, Tierra del Fuego, Argentina.}},
journal = {The American Journal of Tropical Medicine and Hygiene},
year = {2010},
volume = {82},
number = {1},
pages = {55--59},
month = jan,
publisher = {American Society of Tropical Medicine and Hygiene},
affiliation = {Laboratorio Central, Hospital Regional Ushuaia, Centro Nacional de Diagn{\'o}stico e Investigaci{\'o}n de Endemoepidemias (CeNDIE) ANLIS Dr. Carlos G. Malbr{\'a}n, Ministerio de Salud, Instituto de Efectividad Cl{\'i}nica y Sanitaria, Consejo Nacional de Investigaciones Cientificas y T{\'e}cnicas (CONICET), Buenos Aires, Argentina. crismallimaci@yahoo.com.ar},
doi = {10.4269/ajtmh.2010.09-0219},
