@article{Querec:2008jj,
author = {Querec, Troy D and Akondy, Rama S and Lee, Eva K and Cao, Weiping and Nakaya, Helder I and Teuwen, Dirk and Pirani, Ali and Gernert, Kim and Deng, Jiusheng and Marzolf, Bruz and Kennedy, Kathleen and Wu, Haiyan and Bennouna, Soumaya and Oluoch, Herold and Miller, Joseph and Vencio, Ricardo Z and Mulligan, Mark and Aderem, Alan and Ahmed, Rafi and Pulendran, Bali},
title = {{Systems biology approach predicts immunogenicity of the yellow fever vaccine in humans.}},
journal = {Nature Immunology},
year = {2009},
volume = {10},
number = {1},
pages = {116--125},
month = jan,
affiliation = {Emory Vaccine Center, Yerkes National Primate Research Center, 954 Gatewood Road, Atlanta, Georgia 30329, USA.},
doi = {10.1038/ni.1688},
pmid = {19029902},
