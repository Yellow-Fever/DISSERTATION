@article{Li:2014cl,
author = {Li, Xiao-Dan and Shan, Chao and Deng, Cheng-Lin and Ye, Han-Qing and Shi, Pei-Yong and Yuan, Zhi-Ming and Gong, Peng and Zhang, Bo},
title = {{The interface between methyltransferase and polymerase of NS5 is essential for flavivirus replication.}},
journal = {PLoS Neglected Tropical Diseases},
year = {2014},
volume = {8},
number = {5},
pages = {e2891},
month = may,
publisher = {Public Library of Science},
affiliation = {CAS Key Laboratory of Special Pathogens and Biosafety, Center for Emerging Infectious Diseases, Wuhan Institute of Virology, Chinese Academy of Sciences, Wuhan, China; University of Chinese Academy of Sciences, Beijing, China.},
doi = {10.1371/journal.pntd.0002891},
pmid = {24852307},
pmcid = {PMC4031075},
language = {English},
read = {Yes},
rating = {0},
date-added = {2015-11-20T13:14:30GMT+00:00},
date-modified = {2015-12-04T05:00:49GMT+00:00},
abstract = {The flavivirus NS5 harbors both a methyltransferase (MTase) and an RNA-dependent RNA polymerase (RdRP). Both enzyme activities of NS5 are critical for viral replication. Recently, the full-length NS5 crystal structure of Japanese encephalitis virus reveals a conserved MTase-RdRP interface that features two conserved components: a six-residue hydrophobic network and a GTR sequence. Here we showed for the first time that these key interface components are essential for flavivirus replication by various reverse genetics approaches. Interestingly, some replication-impaired variants generated a common compensatory NS5 mutation outside the interface (L322F), providing novel routes to further explore the crosstalk between MTase and RdRP.},
url = {http://dx.plos.org/10.1371/journal.pntd.0002891},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/4B/4B88F291-ED1D-44AA-A31E-318B9D5F9EAA.pdf},
file = {{4B88F291-ED1D-44AA-A31E-318B9D5F9EAA.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/4B/4B88F291-ED1D-44AA-A31E-318B9D5F9EAA.pdf:application/pdf;4B88F291-ED1D-44AA-A31E-318B9D5F9EAA.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/4B/4B88F291-ED1D-44AA-A31E-318B9D5F9EAA.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1371/journal.pntd.0002891}}
}

@article{Li:2005hx,
author = {Li, Fu-Jun and Tsuyama, Naohiro and Ishikawa, Hideaki and Obata, Masanori and Abroun, Saeid and Liu, Shangqin and Otsuyama, Ken-ichiro and Zheng, Xu and Ma, Zi and Maki, Yasuko and Kawano, Michio M},
title = {{A rapid translocation of CD45RO but not CD45RA to lipid rafts in IL-6-induced proliferation in myeloma.}},
journal = {Blood},
year = {2005},
volume = {105},
number = {8},
pages = {3295--3302},
month = apr,
affiliation = {Department of Bio-Signal Analysis, Graduate School of Medicine, Yamaguchi University, 1-1-1 Minami-kogushi, Ube, Yamaguchi 755-8505, Japan.},
doi = {10.1182/blood-2004-10-4083},
pmid = {15626731},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-04-25T20:50:41GMT+00:00},
date-modified = {2015-10-14T22:29:53GMT+00:00},
abstract = {CD45, a receptor-type tyrosine phosphatase, is required for interleukin-6 (IL-6)-induced proliferation in human myeloma cells, which express the shortest isoform, CD45RO, but not the longest isoform, CD45RA. Here, we showed that IL-6 induced the translocation of CD45 to lipid rafts in an isoform-dependent manner. In myeloma cells, CD45RO was translocated to lipid rafts more rapidly than CD45RB, but exogenously expressed CD45RA was not translocated. When an IL-6Ralpha-transfected B-cell line was stimulated with IL-6, CD45RA was not translocated, although CD45RB was. We further confirmed that the translocated CD45 bound to IL-6Ralpha, Lyn, and flotillin-2, and this was followed by the dephosphorylation of the negative regulatory Tyr507 of Lyn. CD45 also bound to phosphoprotein associated with glycosphingolipid-enriched microdomains (PAGs), which were subsequently dephosphorylated, resulting in the release of C-terminal src kinase (Csk) from lipid rafts. Therefore, these results indicate that a rapid translocation of CD45RO to lipid rafts may be responsible for IL-6-induced proliferation, and that the change from CD45RA to CD45RO confers the ability to respond to IL-6 in human myeloma cells.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=15626731&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2005/Li/Blood_2005_Li.pdf},
file = {{Blood_2005_Li.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2005/Li/Blood_2005_Li.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1182/blood-2004-10-4083}}
}

