@article{Umareddy:2006gi,
author = {Umareddy, Indira and Chao, Alex and Sampath, Aruna and Gu, Feng and Vasudevan, Subhash G},
title = {{Dengue virus NS4B interacts with NS3 and dissociates it from single-stranded RNA.}},
journal = {Journal of General Virology},
year = {2006},
volume = {87},
number = {Pt 9},
pages = {2605--2614},
month = sep,
affiliation = {Novartis Institute for Tropical Diseases, 10 Biopolis Road, {\#}05-01 Chromos Building, Singapore.},
doi = {10.1099/vir.0.81844-0},
pmid = {16894199},
language = {English},
read = {Yes},
rating = {0},
date-added = {2013-04-29T20:37:52GMT+00:00},
date-modified = {2015-10-14T22:28:46GMT+00:00},
abstract = {Dengue virus, a member of the family Flaviviridae of positive-strand RNA viruses, has seven non-structural proteins: NS1, NS2A, NS2B, NS3, NS4A, NS4B and NS5. Except for enzymic activities contained within NS3 and NS5, the roles of the other proteins in virus replication and pathogenesis are not well defined. In this study, a physical interaction between NS4B and the helicase domain of NS3 was identified by using a yeast two-hybrid assay. This interaction was further confirmed by biochemical pull-down and immunoprecipitation assays, both with purified proteins and with dengue virus-infected cell lysates. NS4B co-localized with NS3 in the perinuclear region of infected human cells. Furthermore, NS4B dissociated NS3 from single-stranded RNA and consequently enhanced the helicase activity of NS3 in an in vitro unwinding assay. These results suggest that NS4B modulates dengue virus replication via its interaction with NS3.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=16894199&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2006/Umareddy/Journal_of_General_Virology_2006_Umareddy.pdf},
file = {{Journal_of_General_Virology_2006_Umareddy.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2006/Umareddy/Journal_of_General_Virology_2006_Umareddy.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1099/vir.0.81844-0}}
}

