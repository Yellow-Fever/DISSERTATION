file = {{Journal_of_Virology_2011_Pu.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2011/Pu/Journal_of_Virology_2011_Pu.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1128/JVI.01986-10}}
}

