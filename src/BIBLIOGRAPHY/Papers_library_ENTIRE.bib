@article{Wright:2011ca,
author = {Wright, Angela M and Beres, Stephen B and Consamus, Erin N and Long, S Wesley and Flores, Anthony R and Barrios, Roberto and Richter, G Stefan and Oh, So-Young and Garufi, Gabriella and Maier, Hannah and Drews, Ashley L and Stockbauer, Kathryn E and Cernoch, Patricia and Schneewind, Olaf and Olsen, Randall J and Musser, James M},
title = {{Rapidly progressive, fatal, inhalation anthrax-like infection in a human: case report, pathogen genome sequencing, pathology, and coordinated response.}},
journal = {Archives of pathology {\&} laboratory medicine},
year = {2011},
volume = {135},
number = {11},
pages = {1447--1459},
month = nov,
affiliation = {Department of Pathology and Laboratory Medicine, The Methodist Hospital System, Houston, Texas, USA.},
doi = {10.5858/2011-0362-SAIR.1},
pmid = {21882964},
language = {English},
rating = {0},
date-added = {2013-12-13T18:01:49GMT+00:00},
date-modified = {2015-10-14T22:29:48GMT+00:00},
abstract = {CONTEXT:Ten years ago a bioterrorism event involving Bacillus anthracis spores captured the nation's interest, stimulated extensive new research on this pathogen, and heightened concern about illegitimate release of infectious agents. Sporadic reports have described rare, fulminant, and sometimes fatal cases of pneumonia in humans and nonhuman primates caused by strains of Bacillus cereus , a species closely related to Bacillus anthracis.

OBJECTIVES:To describe and investigate a case of rapidly progressive, fatal, anthrax-like pneumonia and the overwhelming infection caused by a Bacillus species of uncertain provenance in a patient residing in rural Texas.

DESIGN:We characterized the genome of the causative strain within days of its recovery from antemortem cultures using next-generation sequencing and performed immunohistochemistry on tissues obtained at autopsy with antibodies directed against virulence proteins of B anthracis and B cereus.

RESULTS:We discovered that the infection was caused by a previously unknown strain of B cereus that was closely related to, but genetically distinct from, B anthracis . The strain contains a plasmid similar to pXO1, a genetic element encoding anthrax toxin and other known virulence factors. Immunohistochemistry demonstrated that several homologs of B anthracis virulence proteins were made in infected tissues, likely contributing to the patient's death.

CONCLUSIONS:Rapid genome sequence analysis permitted us to genetically define this strain, rule out the likelihood of bioterrorism, and contribute effectively to the institutional response to this event. Our experience strongly reinforced the critical value of deploying a well-integrated, anatomic, clinical, and genomic strategy to respond rapidly to a potential emerging, infectious threat to public health.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=21882964&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2011/Wright/Arch._Pathol._Lab._Med._2011_Wright.pdf},
file = {{Arch._Pathol._Lab._Med._2011_Wright.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2011/Wright/Arch._Pathol._Lab._Med._2011_Wright.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.5858/2011-0362-SAIR.1}}
}

@article{deMelo:2011dm,
author = {de Melo, Andr{\'e}a Barbosa and da Silva, Maria da Paz C and Magalh{\~a}es, Maria Cec{\'i}lia F and Gonzales Gil, Laura Helena Vega and Freese de Carvalho, Eduardo M and Braga-Neto, Ulisses M and Bertani, Giovani Rota and Marques, Ernesto T A and Cordeiro, Marli Ten{\'o}rio},
title = {{Description of a prospective 17DD yellow fever vaccine cohort in Recife, Brazil.}},
journal = {The American Journal of Tropical Medicine and Hygiene},
year = {2011},
volume = {85},
number = {4},
pages = {739--747},
month = oct,
affiliation = {Virology and Experimental Therapy Laboratory, Aggeu Magalh{\~a}es Research Center, Fiocruz, Recife, Pernambuco, Brazil. abm@cpqam.fiocruz.br},
doi = {10.4269/ajtmh.2011.10-0496},
pmid = {21976581},
pmcid = {PMC3183786},
language = {English},
rating = {0},
date-added = {2015-05-14T15:53:38GMT+00:00},
date-modified = {2015-10-14T22:29:48GMT+00:00},
abstract = {From September 2005 to March 2007, 238 individuals being vaccinated for the first time with the yellow fever (YF) -17DD vaccine were enrolled in a cohort established in Recife, Brazil. A prospective study indicated that, after immunization, anti-YF immunoglobulin M (IgM) and anti-YF IgG were present in 70.6% (IgM) and 98.3% (IgG) of the vaccinated subjects. All vaccinees developed protective immunity, which was detected by the plaque reduction neutralization test (PRNT) with a geometric mean titer of 892. Of the 238 individuals, 86.6% had IgG antibodies to dengue virus; however, the presence of anti-dengue IgG did not interfere significantly with the development of anti-YF neutralizing antibodies. In a separate retrospective study of individuals immunized with the 17DD vaccine, the PRNT values at 5 and 10 years post-vaccination remained positive but showed a significant decrease in neutralization titer (25% with PRNT titers < 100 after 5 years and 35% after 10 years).},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=21976581&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/B6/B60EB2BB-6744-4542-84F3-CB7193C6850E.pdf},
file = {{B60EB2BB-6744-4542-84F3-CB7193C6850E.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/B6/B60EB2BB-6744-4542-84F3-CB7193C6850E.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.4269/ajtmh.2011.10-0496}}
}

