@article{Yin:2010fi,
author = {Yin, Zundong and Wang, Huanyu and Yang, Jinye and Luo, Huiming and Li, Yixing and Hadler, Stephen C and Sandhu, Hardeep S and Fischer, Marc and Jiang, Yongzhong and Zhang, Zhenguo and Liu, Guifang and Li, Li and Johnson, Barbara W and Liang, Xiaofeng and {Acute Meningitis and Encephalitis Syndrome (AMES) Study Group}},
title = {{Japanese encephalitis disease burden and clinical features of Japanese encephalitis in four cities in the People's Republic of China.}},
journal = {The American Journal of Tropical Medicine and Hygiene},
year = {2010},
volume = {83},
