language = {English},
rating = {0},
date-added = {2012-05-16T19:28:54GMT+00:00},
date-modified = {2015-10-14T22:30:14GMT+00:00},
abstract = {Sterol regulatory element binding protein (SREBP) transcription factors activate genes of lipid metabolism but recent studies indicate they also activate genes involved in other physiologic processes suggesting SREPBs have evolved to connect lipid metabolism with diverse physiologic responses. There are three major mammalian SREBPs and the 1a isoform is specifically expressed at very high levels in macrophages where a recent study showed that it couples lipid synthesis to the proinflammatory phase of the innate immune response. In the current studies, we show that loss of SREBP-1a also results in an increase in apoptosis after exposure to bacterial pore-forming toxins and we show this is a result of a selective reduction in the expression of the antiapoptotic gene Api6. Additional studies demonstrate that SREBP-1a specifically activates the Api6 gene through a binding site in its proximal promoter, thus establishing Api6 as a newly identified SREBP-1a target gene.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=22493063&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/doi/10.1128/MCB.06294-11}}
}

