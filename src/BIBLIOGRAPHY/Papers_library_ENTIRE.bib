uri = {\url{papers3://publication/uuid/10708593-9EF1-4524-885A-8A96A7BAF698}}
}

@article{Karimi:2011ir,
author = {Karimi, Mohammad Hossein and Daneshmandi, Saeed and Pourfathollah, Ali Akbar and Geramizadeh, Bita and Malekhosseini, Seyed Ali and Nikeghbalian, Saman and Yaghobi, Ramin and Bolandparvaz, Shahram},
title = {{Association of IL-6 promoter and IFN-$\gamma$ gene polymorphisms with acute rejection of liver transplantation.}},
journal = {Molecular biology reports},
year = {2011},
volume = {38},
number = {7},
pages = {4437--4443},
month = oct,
affiliation = {Transplant Research Center, Shiraz University of Medical Sciences, Shiraz, Iran.},
doi = {10.1007/s11033-010-0572-6},
pmid = {21132384},
language = {English},
rating = {0},
date-added = {2012-05-04T19:26:22GMT+00:00},
date-modified = {2015-10-14T22:28:46GMT+00:00},
abstract = {Liver transplantation is one of the most important therapies for end-stage liver diseases and is associated with major problems including infections and acute rejection. The outcome of transplantation can be determined by immune responses as a key role in response to the graft. Inflammatory and anti-inflammatory mediators especially cytokines influence the graft microenvironment. Th1 and Th2 immune responses in contrast to regulatory responses cause acute rejection or help graft survival. In this study, we evaluated the gene polymorphisms of IL-6 G-174C, TGF-$\beta$ T + 869C, IL-4 C-590T, and IFN-$\gamma$ T + 874A cytokines in liver transplant patients. ARMS-PCR method was used to characterize IL-6 G-174C, TGF-$\beta$ T + 869C and IFN-$\gamma$ T + 874A polymorphisms and PCR-RFLP using AvaII restriction enzyme was done for IL-4 C-590T characterization in 70 liver transplant patients. Acute rejection episodes were diagnosed according to standard criteria. The analysis of the results showed that IL-6-174 GG genotype ( P = 0.009, OR = 4.333, 95% CI = 1.043-18.000), IL-6-174G allele (P = 0.011, OR = 5.273, 95% CI = 1.454-19.127) was more frequent and IFN-$\gamma$ +874 TT genotype was less frequent (P = 0.043, OR = 0.143, 95% CI = 0.0118-1.190) in acute rejection than in non-rejection patients. TGF-$\beta$ T + 869C and IL-4 C-590T frequencies were not significantly different (P > 0.05). According to the results, it can be conclude that IL-6 G-174C and IFN-$\gamma$ T + 874A gene polymorphisms have predictive values for acute rejection after liver transplantation. High producer genotype of IL-6 is a genetic risk factor and IFN-$\gamma$ is a protective factor for acute rejection development.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=21132384&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2011/Karimi/Mol._Biol._Rep._2011_Karimi.pdf},
file = {{Mol._Biol._Rep._2011_Karimi.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2011/Karimi/Mol._Biol._Rep._2011_Karimi.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1007/s11033-010-0572-6}}
}

