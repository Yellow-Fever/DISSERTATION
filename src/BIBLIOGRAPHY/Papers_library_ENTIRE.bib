@article{Xiao:2004ti,
author = {Xiao, Weihua and Hodge, David R and Wang, Lihua and Yang, Xiaoyi and Zhang, Xiaohu and Farrar, William L},
title = {{NF-kappaB activates IL-6 expression through cooperation with c-Jun and IL6-AP1 site, but is independent of its IL6-NFkappaB regulatory site in autocrine human multiple myeloma cells.}},
journal = {Cancer biology {\&} therapy},
year = {2004},
volume = {3},
number = {10},
pages = {1007--1017},
month = oct,
affiliation = {Basic Research Program, SAIC Frederick, Frederick, Maryland, USA.},
pmid = {15467434},
language = {English},
rating = {0},
date-added = {2012-05-14T19:17:15GMT+00:00},
date-modified = {2015-10-14T22:30:13GMT+00:00},
abstract = {IL-6 stimulates the growth and survival of a variety of tumors. In multiple myeloma (MM), IL-6 prevents spontaneous, drug-induced, and Fas-induced apoptosis. The sources of IL-6 in multiple myeloma appear to be both autocrine and paracrine in nature, with autocrine MM cells exhibiting a constitutively activated expression of the cytokine. Here we present a systematic analysis of the functional roles of the four major transcriptional regulatory sites present in the IL-6 promoter region, IL6-NFkappaB, IL6-C/EBP, IL6-CREB and IL6-AP1. Among these regulatory sites, IL6-AP1 is the most important cis-regulatory site, and plays a vital role in the constitutive expression of IL-6 in IM9 cells. Conversely, the IL6-CREB site, when bound by the transcription factor CREB, exhibits a repression of IL-6 autocrine expression, a result of possible steric hinderence of C/EBP-beta, due to the close proximity and site overlap between the IL6-C/EBP and IL6-CREB sites. Uniquely, although the presence of NF-kappaB protein is fundamental for constitutive expression of IL-6, a functional NF-kappaB site on the IL-6 promoter region is not required. The mechanism of NF-kappaB activation of IL-6 appears to occur through the cooperation with c-Jun protein, that constitutively occupies the IL6-AP1 site, and this indicates a novel transcriptional mechanism for NF-kappaB in the activation of NF-kappaB-driven genes.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=15467434&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/uuid/5C4157CA-B897-4F9B-AF6B-AE5D877C4DD0}}
}

