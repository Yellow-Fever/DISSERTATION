@article{Langmead:2012jh,
author = {Langmead, Ben and Salzberg, Steven L},
title = {{Fast gapped-read alignment with Bowtie 2.}},
journal = {Nature Methods},
year = {2012},
volume = {9},
number = {4},
pages = {357--359},
month = apr,
affiliation = {Center for Bioinformatics and Computational Biology, Institute for Advanced Computer Studies, University of Maryland, College Park, Maryland, USA. blangmea@jhsph.edu},
doi = {10.1038/nmeth.1923},
pmid = {22388286},
pmcid = {PMC3322381},
language = {English},
rating = {0},
date-added = {2012-09-07T22:14:34GMT+00:00},
date-modified = {2015-10-14T22:28:55GMT+00:00},
abstract = {As the rate of sequencing increases, greater throughput is demanded from read aligners. The full-text minute index is often used to make alignment very fast and memory-efficient, but the approach is ill-suited to finding longer, gapped alignments. Bowtie 2 combines the strengths of the full-text minute index with the flexibility and speed of hardware-accelerated dynamic programming algorithms to achieve a combination of high speed, sensitivity and accuracy.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=22388286&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/doi/10.1038/nmeth.1923}}
}

