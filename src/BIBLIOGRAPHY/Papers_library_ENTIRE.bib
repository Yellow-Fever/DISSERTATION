title = {{Molecular analysis of yellow fever virus 17DD vaccine strain.}},
journal = {Mem{\'o}rias do Instituto Oswaldo Cruz},
year = {1991},
volume = {86},
number = {2},
pages = {239--246},
month = apr,
affiliation = {Instituto Oswaldo Cruz, Departamento de Bioquimica e Biologia Molecular, Rio de Janeiro, Brasil.},
pmid = {1842415},
language = {English},
read = {Yes},
rating = {0},
date-added = {2015-05-17T23:38:32GMT+00:00},
date-modified = {2015-10-14T22:30:05GMT+00:00},
abstract = {The Oswaldo Cruz Foundation produces most of the yellow fever (YF) vaccine prepared worldwide. As part of a broader approach to determine the genetic variability in YF 17D seeds and vaccines and its relevance to viral attenuation the 17DD virus was purified directly from chick embryo homogenates which is the source of virus used for vaccination of millions of people in Brazil and other countries for half a century. Neutralization and hemagglutination tests showed that the purified virus is similar to the original stock. Furthermore, radioimmune precipitation of 35S-methionine-labeled viral proteins using mouse hyperimmune ascitic fluid revealed identical patterns for the purified 17DD virus and the YF 17D-204 strain except for the 17DD E protein which migrated slower on SDS-PAGE. This difference is likely to be due to N-linked glycosylation. Finally, comparison by northern blot hybridization of virion RNAs of purified 17DD with two other strains of YF 17D virus revealed only genome-sized molecules for all three viruses. These observations suggest that the vaccine phenotype is primarily associated with the accumulation of mutations.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=1842415&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/99/9976193D-C368-4A7C-A6EE-917845FC5EF1.pdf},
file = {{9976193D-C368-4A7C-A6EE-917845FC5EF1.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/99/9976193D-C368-4A7C-A6EE-917845FC5EF1.pdf:application/pdf;9976193D-C368-4A7C-A6EE-917845FC5EF1.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/99/9976193D-C368-4A7C-A6EE-917845FC5EF1.pdf:application/pdf}},
