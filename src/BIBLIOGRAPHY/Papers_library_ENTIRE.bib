@article{Schmidt:2000di,
author = {Schmidt, W N and Stapleton, J T and LaBrecque, D R and Mitros, F A and Kirby, P A and Phillips, M J and Brashear, D L},
title = {{Hepatitis C virus (HCV) infection and cryoglobulinemia: analysis of whole blood and plasma HCV-RNA concentrations and correlation with liver histology.}},
journal = {Hepatology},
year = {2000},
volume = {31},
number = {3},
pages = {737--744},
month = mar,
affiliation = {Department of Internal Medicine, The University of Iowa College of Medicine, Iowa City, IA 52242-1081, USA. warren-schmidt@uiowa.edu},
doi = {10.1002/hep.510310326},
pmid = {10706566},
language = {English},
rating = {0},
date-added = {2013-02-01T17:40:31GMT+00:00},
date-modified = {2015-10-14T22:29:25GMT+00:00},
abstract = {The influence of cryoprecipitate (CP) on liver histology and peripheral titers of hepatitis C virus (HCV) RNA was evaluated for 115 patients with chronic hepatitis. Fifty-four patients had measurable CP levels whereas 61 did not. Assessment of liver biopsies for grade of fibrosis revealed that patients with CP had increased fibrosis (P <.001) and incidence of cirrhosis (P =.001) compared with those without CP. In contrast, there was not a significant difference in the inflammatory activity score between the 2 groups. HCV RNA in whole blood (WB) and plasma (Pl) was evaluated in patients with or without CP by end-point-limiting dilution titer. Among patients with CP, WB titers were significantly higher than Pl titers (P <.001); however, there was no difference in WB or Pl titers in patients without CP (P =.068). Histological activity and fibrosis scores of patients from either group were compared with peripheral viral titers of WB and Pl, percentage of CP, rheumatoid factor (RF) titer, and serum alanine transaminase (ALT). There were significant correlations between the amount of fibrosis and the percentage of CP and rheumatoid factor titer, yet neither of the latter parameters was correlated with inflammatory activity. These data suggest that patients with CP and chronic hepatitis owing to HCV are more likely to have progressive disease than patients without CP. Furthermore, the presence of CP in patients infected with HCV appears to influence the amount of virus detected in patient Pl, suggesting that WB assays may be more reliable for HCV-RNA quantitation in patients with CP.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=10706566&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/doi/10.1002/hep.510310326}}
}

@article{Bredenbeek:2006fq,
author = {Bredenbeek, Peter J and Molenkamp, Richard and Spaan, Willy J M and Deubel, Vincent and Marianneau, Phillippe and Salvato, Maria S and Moshkoff, Dmitry and Zapata, Juan and Tikhonov, Ilia and Patterson, Jean and Carrion, Ricardo and Ticer, Anysha and Brasky, Kathleen and Lukashevich, Igor S},
title = {{A recombinant Yellow Fever 17D vaccine expressing Lassa virus glycoproteins.}},
journal = {Virology},
year = {2006},
volume = {345},
number = {2},
pages = {299--304},
month = feb,
affiliation = {Department of Medical Microbiology, Center for Infectious Diseases, Leiden University Medical Center, Leiden, The Netherlands.},
doi = {10.1016/j.virol.2005.12.001},
pmid = {16412488},
pmcid = {PMC1388090},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-06-04T14:45:11GMT+00:00},
date-modified = {2015-10-14T22:29:25GMT+00:00},
abstract = {The Yellow Fever Vaccine 17D (YFV17D) has been used as a vector for the Lassa virus glycoprotein precursor (LASV-GPC) resulting in construction of YFV17D/LASV-GPC recombinant virus. The virus was replication-competent and processed the LASV-GPC in cell cultures. The recombinant replicated poorly in guinea pigs but still elicited specific antibodies against LASV and YFV17D antigens. A single subcutaneous injection of the recombinant vaccine protected strain 13 guinea pigs against fatal Lassa Fever. This study demonstrates the potential to develop an YFV17D-based bivalent vaccine against two viruses that are endemic in the same area of Africa.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=16412488&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2006/Bredenbeek/Virology_2006_Bredenbeek.pdf},
file = {{Virology_2006_Bredenbeek.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2006/Bredenbeek/Virology_2006_Bredenbeek.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1016/j.virol.2005.12.001}}
}

@article{Schlesinger:1995wja,
author = {Schlesinger, J J and Chapman, S},
title = {{Neutralizing F(ab')2 fragments of protective monoclonal antibodies to yellow fever virus (YF) envelope protein fail to protect mice against lethal YF encephalitis.}},
journal = {The Journal of General Virology},
year = {1995},
volume = {76 ( Pt 1)},
pages = {217--220},
month = jan,
affiliation = {University of Rochester School of Medicine {\&} Dentistry, NY 14621.},
pmid = {7844536},
language = {English},
rating = {0},
date-added = {2014-08-27T18:18:57GMT+00:00},
date-modified = {2015-10-14T22:29:25GMT+00:00},
abstract = {Monoclonal antibodies (MAbs) prepared against the yellow fever virus (YF) vaccine strain 17D (17D YF) envelope E protein were used to investigate Fc piece involvement in antibody-mediated protection against YF encephalitis in mice 17D YF passaged either in Vero cells or in mouse brain (P-YF) to increase neurovirulence was used. To avoid uncertainty concerning antibody clearance and blood-brain barrier penetration, and to directly compare protective activity with neutralization in vitro, pre-formed antibody-virus complexes were injected intracerebrally or assayed for plaque formation in parallel. F(ab')2 fragments of an IgG2a MAb that strongly neutralized both YF strains retained molar equivalent neutralizing activity in vitro, but did not protect. However, further incubation of such F(ab')2-virus antibody complexes with rabbit IgG, but not F(ab')2 anti-mouse IgG resulted in protection. To unambiguously test for Fc piece involvement in this model we derived an IgG2a isotype switch variant from a protective IgG1 MAb-secreting hybridoma and prepared F(ab')2 fragments of the derivative. Intact and fragmented antibodies exhibited weak neutralizing activity. The variant antibody failed to protect against P-YF, but against considerably less neurovirulent 17D YF its protective capacity was 10-fold higher than that of its IgG1 parent. F(ab')2 fragments of the variant did not protect. Together, these results provide strong evidence of an in vivo protective function for the anti-virion antibody Fc piece and indicate that in vitro neutralizing activity as a predictor of antibody protective capacity is dependent on Fc piece integrity and isotype.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=7844536&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/1995/Schlesinger/J._Gen._Virol._1995_Schlesinger.pdf},
file = {{J._Gen._Virol._1995_Schlesinger.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/1995/Schlesinger/J._Gen._Virol._1995_Schlesinger.pdf:application/pdf}},
uri = {\url{papers3://publication/uuid/5EA19365-3A3B-4E09-9A9B-87CE0AB3D6EE}}
}

@article{Cox:2013ex,
author = {Cox, Maureen A and Kahan, Shannon M and Zajac, Allan J},
title = {{Anti-viral CD8 T cells and the cytokines that they love}},
