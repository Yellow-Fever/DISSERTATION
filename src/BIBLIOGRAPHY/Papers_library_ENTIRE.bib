@article{Vasconcelos:2015bp,
author = {Monath, Thomas P and Vasconcelos, Pedro F C},
title = {{Yellow fever.}},
journal = {Journal of Clinical Virology},
year = {2015},
volume = {64},
pages = {160--173},
month = mar,
affiliation = {Hookipa Biotech AG, Vienna, Austria; PaxVax Inc., Menlo Park Redwood City, CA, USA. Electronic address: tpmonath@gmail.com.},
doi = {10.1016/j.jcv.2014.08.030},
pmid = {25453327},
language = {English},
read = {Yes},
rating = {0},
date-added = {2015-06-20T04:11:02GMT+00:00},
date-modified = {2016-02-09T16:13:06GMT+00:00},
abstract = {Yellow fever, a mosquito-borne flavivirus disease occurs in tropical areas of South America and Africa. It is a disease of major historical importance, but remains a threat to travelers to and residents of endemic areas despite the availability of an effective vaccine for nearly 70 years. An important aspect is the receptivity of many non-endemic areas to introduction and spread of yellow fever. This paper reviews the clinical aspects, pathogenesis, and epidemiology of yellow fever, with an emphasis on recent changes in the distribution and incidence of the disease. Recent knowledge about yellow fever 17D vaccine mechanism of action and safety are discussed.},
url = {http://linkinghub.elsevier.com/retrieve/pii/S1386653214003692},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/F0/F0FE31AB-CF59-4C54-9983-C741604EA09B.pdf},
file = {{F0FE31AB-CF59-4C54-9983-C741604EA09B.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/F0/F0FE31AB-CF59-4C54-9983-C741604EA09B.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1016/j.jcv.2014.08.030}}
}

@article{Messina:2014jo,
author = {Messina, Jane P and Brady, Oliver J and Scott, Thomas W and Zou, Chenting and Pigott, David M and Duda, Kirsten A and Bhatt, Samir and Katzelnick, Leah and Howes, Rosalind E and Battle, Katherine E and Simmons, Cameron P and Hay, Simon I},
title = {{Global Spread of Dengue Virus Types: Mapping the 70 Year History.}},
journal = {Trends in Microbiology},
year = {2014},
volume = {22},
number = {3},
pages = {138--146},
month = mar,
publisher = {Elsevier},
affiliation = {Spatial Ecology and Epidemiology Group, Department of Zoology, University of Oxford, South Parks Road, Oxford OX1 3PS, UK. Electronic address: jane.messina@zoo.ox.ac.uk.},
doi = {10.1016/j.tim.2013.12.011},
pmid = {24468533},
pmcid = {PMC3946041},
language = {English},
read = {Yes},
rating = {0},
date-added = {2016-01-21T05:09:42GMT+00:00},
date-modified = {2016-01-21T06:45:30GMT+00:00},
abstract = {Since the first isolation of dengue virus (DENV) in 1943, four types have been identified. Global phenomena such as urbanization and international travel are key factors in facilitating the spread of dengue. Documenting the type-specific record of DENV spread has important implications for understanding patterns in dengue hyperendemicity and disease severity as well as vaccine design and deployment strategies. Existing studies have examined the spread of DENV types at regional or local scales, or described phylogeographic relationships within a single type. Here we summarize the global distribution of confirmed instances of each DENV type from 1943 to 2013 in a series of global maps. These show the worldwide expansion of the types, the expansion of disease hyperendemicity, and the establishment of an increasingly important infectious disease of global public health significance.},
url = {http://www.cell.com/article/S0966842X13002734/fulltext},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/77/77132BC8-185F-4930-82B5-CCE3C3EE10A5.pdf},
file = {{77132BC8-185F-4930-82B5-CCE3C3EE10A5.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/77/77132BC8-185F-4930-82B5-CCE3C3EE10A5.pdf:application/pdf;77132BC8-185F-4930-82B5-CCE3C3EE10A5.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/77/77132BC8-185F-4930-82B5-CCE3C3EE10A5.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1016/j.tim.2013.12.011}}
}

@article{Afreen:2015hj,
author = {Afreen, Nazia and Naqvi, Irshad H and Broor, Shobha and Ahmed, Anwar and Parveen, Shama},
title = {{Phylogenetic and Molecular Clock Analysis of Dengue Serotype 1 and 3 from New Delhi, India.}},
journal = {PLoS ONE},
year = {2015},
volume = {10},
number = {11},
pages = {e0141628},
publisher = {Public Library of Science},
affiliation = {Centre for Interdisciplinary Research in Basic Sciences, Jamia Millia Islamia, New Delhi, India.},
doi = {10.1371/journal.pone.0141628},
pmid = {26536458},
pmcid = {PMC4633233},
language = {English},
read = {Yes},
rating = {0},
date-added = {2016-01-21T04:35:33GMT+00:00},
date-modified = {2016-01-21T06:45:30GMT+00:00},
abstract = {Dengue fever is the most prevalent arboviral disease in the tropical and sub-tropical regions of the world. The present report describes molecular detection and serotyping of dengue viruses in acute phase blood samples collected from New Delhi, India. Phylogenetic and molecular clock analysis of dengue virus serotype 1 and 3 strains were also investigated. Dengue virus infection was detected in 68.87% out of 604 samples tested by RT-PCR between 2011 {\&} 2014. Dengue serotype 1 was detected in 25.48% samples, dengue serotype 2 in 79.56% samples and dengue serotype 3 in 11.29% samples. Dengue serotype 4 was not detected. Co-infection by more than one dengue serotype was detected in 18.26% samples. Envelope gene of 29 DENV-1 and 14 DENV-3 strains were sequenced in the study. All the DENV-1 strains grouped with the American African genotype. All DENV-3 strains were found to belong to Genotype III. Nucleotide substitution rates of dengue 1 and 3 viruses were determined in the study. Time to the most recent common ancestor (TMRCA) of dengue 1 viruses was determined to be 132 years. TMRCA of DENV-3 viruses was estimated to be 149 years. Bayesian skyline plots were constructed for Indian DENV-1 and 3 strains which showed a decrease in population size since 2005 in case of DENV- 1 strains while no change was observed in recent years in case of DENV-3 strains. The study also revealed a change in the dominating serotype in Delhi, India in recent years. The study will be helpful in formulating control strategies for the outbreaks. In addition, it will also assist in tracking the movement and evolution of this emerging virus.},
url = {http://journals.plos.org/plosone/article?id=10.1371/journal.pone.0141628},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/08/080D4129-0F4B-4F72-A859-399729877407.pdf},
file = {{080D4129-0F4B-4F72-A859-399729877407.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/08/080D4129-0F4B-4F72-A859-399729877407.pdf:application/pdf;080D4129-0F4B-4F72-A859-399729877407.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/08/080D4129-0F4B-4F72-A859-399729877407.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1371/journal.pone.0141628}}
}

@article{Youn:2012jt,
author = {Youn, Soonjeon and Li, Tuo and McCune, Broc T and Edeling, Melissa A and Fremont, Daved H and Cristea, Ileana M and Diamond, Michael S},
title = {{Evidence for a Genetic and Physical Interaction Between Nonstructural Proteins NS1 and NS4B that Modulates Replication of West Nile Virus.}},
journal = {Journal of Virology},
year = {2012},
volume = {86},
number = {13},
pages = {7360--7371},
month = jul,
publisher = {American Society for Microbiology},
affiliation = {Department of Medicine, Washington University School of Medicine, St. Louis, Missouri, USA.},
doi = {10.1128/JVI.00157-12},
pmid = {22553322},
pmcid = {PMC3416313},
language = {English},
read = {Yes},
rating = {0},
date-added = {2016-01-21T01:43:40GMT+00:00},
date-modified = {2016-01-21T06:45:30GMT+00:00},
abstract = {Flavivirus NS1 is a nonstructural glycoprotein that is expressed on the cell surface and secreted into the extracellular space. Despite its transit through the secretory pathway, NS1 is an essential gene linked to early viral RNA replication. How this occurs has remained a mystery given the disparate localization of NS1 and the viral RNA replication complex, as the latter is present on the cytosolic face of the endoplasmic reticulum (ER). We recently identified an N-terminal di-amino acid motif in NS1 that modulates protein targeting and affected viral replication. Exchange of two amino acids at positions 10 and 11 from dengue virus (DENV) into West Nile virus (WNV) NS1 (RQ10NK) changed its relative surface expression and secretion and attenuated infectivity. However, the phenotype of WNV containing NS1 RQ10NK was unstable, as within two passages heterogeneous plaque variants were observed. Here, using a mutant WNV encoding the NS1 RQ10NK mutation, we identified a suppressor mutation (F86C) in NS4B, a virally encoded transmembrane protein with loops on both the luminal and cytoplasmic sides of the ER membrane. Introduction of NS4B F86C specifically rescued RNA replication of mutant WNV but did not affect the wild-type virus. Mass spectrometry and coimmunoprecipitation studies established a novel physical interaction between NS1 and NS4B, suggesting a mechanism for how luminal NS1 conveys signals to the cytoplasm to regulate RNA replication.},
url = {http://jvi.asm.org/content/86/13/7360.full},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/D9/D930A07E-DE18-42F6-B36F-3E0A8104A25D.pdf},
file = {{D930A07E-DE18-42F6-B36F-3E0A8104A25D.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/D9/D930A07E-DE18-42F6-B36F-3E0A8104A25D.pdf:application/pdf;D930A07E-DE18-42F6-B36F-3E0A8104A25D.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/D9/D930A07E-DE18-42F6-B36F-3E0A8104A25D.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1128/JVI.00157-12}}
}

@article{Youn:2013hj,
author = {Youn, Soonjeon and Ambrose, Rebecca L and Mackenzie, Jason M and Diamond, Michael S},
title = {{Non-structural Protein-1 is Required for West Nile Virus Replication Complex Formation and Viral RNA Synthesis.}},
journal = {Virology Journal},
year = {2013},
volume = {10},
number = {1},
pages = {339},
publisher = {BioMed Central},
affiliation = {Department of Medicine, Washington University School of Medicine, Saint Louis, MO 63110, USA. diamond@borcim.wustl.edu.},
doi = {10.1186/1743-422X-10-339},
pmid = {24245822},
pmcid = {PMC3842638},
language = {English},
read = {Yes},
rating = {0},
date-added = {2016-01-21T01:42:07GMT+00:00},
date-modified = {2016-01-21T06:45:30GMT+00:00},
abstract = {BACKGROUND:Flavivirus NS1 is a non-structural glycoprotein that is expressed on the cell surface and secreted into the extracellular space, where it acts as an antagonist of complement pathway activation. Despite its transit through the secretory pathway and intracellular localization in the lumen of the endoplasmic reticulum and Golgi vesicles, NS1 is as an essential gene for flavivirus replication. How NS1 modulates infection remains uncertain given that the viral RNA replication complex localizes to the cytosolic face of the endoplasmic reticulum.

METHODS AND RESULTS:Using a trans-complementation assay, we show that viruses deleted for NS1 ($\Delta$-NS1) can be rescued by transgenic expression of NS1 from West Nile virus (WNV) or heterologous flaviviruses in the absence of adaptive mutations. In viral lifecycle experiments, we demonstrate that WNV NS1 was not required for virus attachment or input strand translation of the infectious viral RNA, but was necessary for negative and positive strand RNA synthesis and formation of the endoplasmic reticulum-associated replication complex.

CONCLUSIONS:WNV RNA lacking intact NS1 genes was efficiently translated but failed to form canonical replication complexes at early times after infection, which resulted in an inability to replicate viral RNA. These results expand on prior studies with yellow fever and Kunjin viruses to show that flavivirus NS1 has an essential co-factor role in regulating replication complex formation and viral RNA synthesis.},
url = {http://virologyj.biomedcentral.com/articles/10.1186/1743-422X-10-339},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/43/43E0C0E7-AFDC-4979-9950-C2FEB4399E96.pdf},
file = {{43E0C0E7-AFDC-4979-9950-C2FEB4399E96.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/43/43E0C0E7-AFDC-4979-9950-C2FEB4399E96.pdf:application/pdf;43E0C0E7-AFDC-4979-9950-C2FEB4399E96.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/43/43E0C0E7-AFDC-4979-9950-C2FEB4399E96.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1186/1743-422X-10-339}}
}

@article{Lubick:2015fg,
author = {Lubick, Kirk J and Robertson, Shelly J and McNally, Kristin L and Freedman, Brett A and Rasmussen, Angela L and Taylor, R Travis and Walts, Avram D and Tsuruda, Seitaro and Sakai, Mizuki and Ishizuka, Mariko and Boer, Elena F and Foster, Erin C and Chiramel, Abhilash I and Addison, Conrad B and Green, Richard and Kastner, Daniel L and Katze, Michael G and Holland, Steven M and Forlino, Antonella and Freeman, Alexandra F and Boehm, Manfred and Yoshii, Kentaro and Best, Sonja M},
title = {{Flavivirus Antagonism of Type I Interferon Signaling Reveals Prolidase as a Regulator of IFNAR1 Surface Expression.}},
journal = {Cell host {\&} microbe},
year = {2015},
volume = {18},
number = {1},
pages = {61--74},
month = jul,
publisher = {Elsevier},
affiliation = {Laboratory of Virology, Rocky Mountain Laboratories, National Institute of Allergy and Infectious Diseases, NIH, Hamilton, MT 59840, USA.},
doi = {10.1016/j.chom.2015.06.007},
pmid = {26159719},
pmcid = {PMC4505794},
language = {English},
read = {Yes},
rating = {0},
date-added = {2016-01-18T22:19:24GMT+00:00},
date-modified = {2016-01-21T02:06:15GMT+00:00},
abstract = {Type I interferon (IFN-$\alpha$/$\beta$ or IFN-I) signals through two receptor subunits, IFNAR1 and IFNAR2, to orchestrate sterile and infectious immunity. Cellular pathways that regulate IFNAR1 are often targeted by viruses to suppress the antiviral effects of IFN-I. Here we report that encephalitic flaviviruses, including tick-borne encephalitis virus and West Nile virus, antagonize IFN-I signaling by inhibiting IFNAR1 surface expression. Loss of IFNAR1 was associated with binding of the viral IFN-I antagonist, NS5, to prolidase (PEPD), a cellular dipeptidase implicated in primary immune deficiencies in humans. Prolidase was required for IFNAR1 maturation and accumulation, activation of IFN$\beta$-stimulated gene induction, and IFN-I-dependent viral control. Human fibroblasts derived from patients with genetic prolidase deficiency exhibited decreased IFNAR1 surface expression and reduced IFN$\beta$-stimulated signaling. Thus, by understanding flavivirus IFN-I antagonism, prolidase is revealed as a central regulator of IFN-I responses.},
url = {http://linkinghub.elsevier.com/retrieve/pii/S1931312815002553},
uri = {\url{papers3://publication/doi/10.1016/j.chom.2015.06.007}}
}

@article{Best:2005kg,
author = {Best, Sonja M and Morris, Keely L and Shannon, Jeffrey G and Robertson, Shelly J and Mitzel, Dana N and Park, Gregory S and Boer, Elena and Wolfinbarger, James B and Bloom, Marshall E},
title = {{Inhibition of Interferon-Stimulated JAK-STAT Signaling by a Tick-borne Flavivirus and Identification of NS5 as an Interferon Antagonist.}},
journal = {Journal of Virology},
year = {2005},
volume = {79},
number = {20},
pages = {12828--12839},
month = oct,
publisher = {American Society for Microbiology},
affiliation = {Laboratory of Persistent Viral Diseases, Rocky Mountain Laboratories, NIAID, NIH, Hamilton, MT 59840, USA. sbest@niaid.nih.gov},
doi = {10.1128/JVI.79.20.12828-12839.2005},
pmid = {16188985},
pmcid = {PMC1235813},
language = {English},
read = {Yes},
rating = {0},
date-added = {2016-01-18T22:13:21GMT+00:00},
date-modified = {2016-01-21T02:05:56GMT+00:00},
abstract = {The tick-borne encephalitis (TBE) complex of viruses, genus Flavivirus, can cause severe encephalitis, meningitis, and/or hemorrhagic fevers. Effective interferon (IFN) responses are critical to recovery from infection with flaviviruses, and the mosquito-borne flaviviruses can inhibit this response. However, little is known about interactions between IFN signaling and TBE viruses. Langat virus (LGTV), a member of the TBE complex of viruses, was found to be highly sensitive to the antiviral effects of IFN. However, LGTV infection inhibited IFN-induced expression of a reporter gene driven by either IFN-alpha/beta- or IFN-gamma-responsive promoters. This indicated that LGTV can inhibit the IFN-mediated JAK-STAT (Janus kinase-signal transducer and activator of transcription) pathway of signal transduction. The mechanism of inhibition was due to blocks in the phosphorylation of both Janus kinases, Jak1 and Tyk2, during IFN-alpha signaling and at least a failure of Jak1 phosphorylation following IFN-gamma stimulation. To determine the viral protein(s) responsible, we individually expressed all nonstructural (NS) proteins and examined their ability to inhibit signal transduction. Expression of NS5 alone inhibited STAT1 phosphorylation in response to IFN, thus identifying NS5 as a potential IFN antagonist. Examination of interactions between NS5 and cellular proteins revealed that NS5 associated with IFN-alpha/beta and -gamma receptor complexes. Importantly, inhibition of JAK-STAT signaling and NS5-IFN receptor interactions were demonstrated in LGTV-infected human monocyte-derived dendritic cells, important target cells for early virus replication. Because NS5 may interfere with both innate and acquired immune responses to virus infection, this protein may have a significant role in viral pathogenesis.},
url = {http://jvi.asm.org/content/79/20/12828.full},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/61/61E0430E-D9B1-4D41-B200-79D14710D173.pdf},
file = {{61E0430E-D9B1-4D41-B200-79D14710D173.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/61/61E0430E-D9B1-4D41-B200-79D14710D173.pdf:application/pdf;61E0430E-D9B1-4D41-B200-79D14710D173.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/61/61E0430E-D9B1-4D41-B200-79D14710D173.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1128/JVI.79.20.12828-12839.2005}}
}

