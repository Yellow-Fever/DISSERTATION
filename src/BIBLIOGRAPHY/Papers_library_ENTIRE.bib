title = {{Stat3 activation of NF-{kappa}B p100 processing involves CBP/p300-mediated acetylation.}},
journal = {Proceedings of the National Academy of Sciences of the United States of America},
year = {2006},
volume = {103},
number = {19},
pages = {7264--7269},
month = may,
affiliation = {Department of Medicine, Roswell Park Cancer Institute, Buffalo, NY 14263, USA.},
doi = {10.1073/pnas.0509808103},
pmid = {16651533},
pmcid = {PMC1464331},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-05-14T18:16:37GMT+00:00},
date-modified = {2015-10-14T22:29:32GMT+00:00},
abstract = {Activation of the noncanonical NF-kappaB signaling pathway involved in the proteolytic processing of NF-kappaB p100 to p52 is tightly regulated, and overproduction of p52 leads to lymphocyte hyperplasia and transformation. We have demonstrated that active but not latent Stat3, expressed in many types of human cancers involved in cell proliferation and survival, induces p100 processing to p52 by activation of IKKalpha and subsequent phosphorylation of p100. The Stat3-mediated p100 processing to p52 requires activation of Stat3 by the acetyltransferase activity of cAMP-response element-binding protein (CREB)-binding protein (CBP)/p300. A mutant of Stat3 defective in acetylation blocked Stat3-mediated p100 processing to p52 and acted as a dominant negative in blocking the production of p52. Furthermore, overexpression of p52 protected cells from apoptotic cell death. Thus, activation of the processing of p100 to p52 by Stat3 may represent one of the common pathways used by cancer cells to survive and escape therapy.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=16651533&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2006/Nadiminty/Proc._Natl._Acad._Sci._U.S.A._2006_Nadiminty.pdf},
file = {{Proc._Natl._Acad._Sci._U.S.A._2006_Nadiminty.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2006/Nadiminty/Proc._Natl._Acad._Sci._U.S.A._2006_Nadiminty.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1073/pnas.0509808103}}
}

