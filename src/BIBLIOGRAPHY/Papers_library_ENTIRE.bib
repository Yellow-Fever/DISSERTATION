@article{Otaki:2007un,
author = {Otaki, Momoko and Jiang, Da-Peng and Sasayama, Mikiko and Nagano-Fujii, Motoko and Hotta, Hak},
title = {{Generation of recombinant adenovirus expressing siRNA against the L mRNA of measles virus and subacute sclerosing panencephalitis virus.}},
journal = {Microbiology and Immunology},
year = {2007},
volume = {51},
number = {10},
pages = {985--991},
affiliation = {Division of Microbiology, Kobe University Graduate School of Medicine, Kobe, Hyogo 650-0017, Japan.},
