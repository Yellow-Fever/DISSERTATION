@article{Koster:2012bv,
author = {Koster, Frederick and Gouveia, Kristine and Zhou, Yue and Lowery, Kristin and Russell, Robert and MacInnes, Heather and Pollock, Zemmie and Layton, R Colby and Cromwell, Jennifer and Toleno, Denise and Pyle, John and Zubelewicz, Michael and Harrod, Kevin and Sampath, Rangarajan and Hofstadler, Steven and Gao, Peng and Liu, Yushi and Cheng, Yung-Sung},
title = {{Exhaled aerosol transmission of pandemic and seasonal H1N1 influenza viruses in the ferret.}},
journal = {PLoS ONE},
year = {2012},
volume = {7},
number = {4},
pages = {e33118},
affiliation = {Program in Applied Science, Lovelace Respiratory Research Institute, Albuquerque, New Mexico, United States of America. fkoster@lrri.org},
doi = {10.1371/journal.pone.0033118},
pmid = {22509254},
pmcid = {PMC3317934},
language = {English},
read = {Yes},
rating = {0},
date-added = {2013-12-13T15:56:08GMT+00:00},
date-modified = {2015-10-14T22:29:36GMT+00:00},
abstract = {Person-to-person transmission of influenza viruses occurs by contact (direct and fomites) and non-contact (droplet and small particle aerosol) routes, but the quantitative dynamics and relative contributions of these routes are incompletely understood. The transmissibility of influenza strains estimated from secondary attack rates in closed human populations is confounded by large variations in population susceptibilities. An experimental method to phenotype strains for transmissibility in an animal model could provide relative efficiencies of transmission. We developed an experimental method to detect exhaled viral aerosol transmission between unanesthetized infected and susceptible ferrets, measured aerosol particle size and number, and quantified the viral genomic RNA in the exhaled aerosol. During brief 3-hour exposures to exhaled viral aerosols in airflow-controlled chambers, three strains of pandemic 2009 H1N1 strains were frequently transmitted to susceptible ferrets. In contrast one seasonal H1N1 strain was not transmitted in spite of higher levels of viral RNA in the exhaled aerosol. Among three pandemic strains, the two strains causing weight loss and illness in the intranasally infected 'donor' ferrets were transmitted less efficiently from the donor than the strain causing no detectable illness, suggesting that the mucosal inflammatory response may attenuate viable exhaled virus. Although exhaled viral RNA remained constant, transmission efficiency diminished from day 1 to day 5 after donor infection. Thus, aerosol transmission between ferrets may be dependent on at least four characteristics of virus-host relationships including the level of exhaled virus, infectious particle size, mucosal inflammation, and viral replication efficiency in susceptible mucosa.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=22509254&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2012/Koster/PLoS_ONE_2012_Koster.pdf},
file = {{PLoS_ONE_2012_Koster.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2012/Koster/PLoS_ONE_2012_Koster.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1371/journal.pone.0033118}}
}

@article{Brimijoin:2013kj,
author = {Brimijoin, Stephen and Shen, Xiaoyun and Orson, Frank and Kosten, Thomas},
title = {{Prospects, promise and problems on the road to effective vaccines and related therapies for substance abuse.}},
journal = {Expert Review of Vaccines},
year = {2013},
volume = {12},
number = {3},
pages = {323--332},
month = mar,
affiliation = {Department of Molecular Pharmacology and Experimental Therapeutics, Mayo Clinic, Rochester, MN, USA. brimijoin@mayo.edu},
doi = {10.1586/erv.13.1},
pmid = {23496671},
pmcid = {PMC3738206},
language = {English},
read = {Yes},
rating = {0},
date-added = {2014-06-27T14:37:01GMT+00:00},
date-modified = {2015-10-14T22:29:36GMT+00:00},
abstract = {This review addresses potential new treatments for stimulant drugs of abuse, especially cocaine. Clinical trials of vaccines against cocaine and nicotine have been completed with the generally encouraging result that subjects showing high titers of antidrug antibody experience a reduction in drug reward, which may aid in cessation. New vaccine technologies, including gene transfer of highly optimized monoclonal antibodies, are likely to improve such outcomes further. In the special case of cocaine abuse, a metabolic enzyme is emerging as an alternative or added therapeutic intervention, which would also involve gene transfer. Such approaches still require extensive studies of safety and efficacy, but they may eventually contribute to a robust form of in~vivo drug interception that greatly reduces the risks of addiction relapse.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=23496671&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2013/Brimijoin/Expert_Rev_Vaccines_2013_Brimijoin.pdf},
file = {{Expert_Rev_Vaccines_2013_Brimijoin.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2013/Brimijoin/Expert_Rev_Vaccines_2013_Brimijoin.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1586/erv.13.1}}
}

@article{Neves:2010fa,
author = {Neves, Patr{\'i}cia C C and Rudersdorf, Richard A and Galler, Ricardo and Bonaldo, Myrna C and de Santana, Marlon Gilsepp Veloso and Mudd, Philip A and Martins, Maur{\'i}cio A and Rakasz, Eva G and Wilson, Nancy A and Watkins, David I},
title = {{CD8+ gamma-delta TCR+ and CD4+ T cells produce IFN-$\gamma$ at 5-7 days after yellow fever vaccination in Indian rhesus macaques, before the induction of classical antigen-specific T cell responses.}},
journal = {Vaccine},
year = {2010},
volume = {28},
number = {51},
pages = {8183--8188},
month = nov,
affiliation = {Vice-diretoria de Desenvolvimento Tecnol{\'o}gico, Bio-Manguinhos, Funda{\c c}{\~a}o Oswaldo Cruz, Av. Brasil 4365, Manguinhos 21040-360, Rio de Janeiro, Brazil.},
doi = {10.1016/j.vaccine.2010.09.090},
pmid = {20939995},
pmcid = {PMC3179417},
language = {English},
rating = {0},
date-added = {2014-08-27T18:46:09GMT+00:00},
date-modified = {2015-10-14T22:30:22GMT+00:00},
abstract = {The yellow fever 17D (YF-17D) vaccine is one of the most efficacious vaccines developed to date. Interestingly, vaccination with YF-17D induces IFN-$\gamma$ production early after vaccination (days 5-7) before the development of classical antigen-specific CD8(+) and CD4(+) T cell responses. Here we investigated the cellular source of this early IFN-$\gamma$ production. At days 5 and 7 post-vaccination activated CD8(+) gamma-delta TCR T cells produced IFN-$\gamma$ and TNF-$\alpha$. Activated CD4(+) T cells produced IFN-$\gamma$ and TNF-$\alpha$ at day 7 post-vaccination. This early IFN-$\gamma$ production was also induced after vaccination with recombinant YF-17D (rYF-17D), but was not observed after recombinant Adenovirus type 5 (rAd5) vaccination. Early IFN-$\gamma$ production, therefore, might be an important aspect of yellow fever vaccination.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=20939995&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2010/Neves/Vaccine_2010_Neves.pdf},
file = {{Vaccine_2010_Neves.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2010/Neves/Vaccine_2010_Neves.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1016/j.vaccine.2010.09.090}}
}

