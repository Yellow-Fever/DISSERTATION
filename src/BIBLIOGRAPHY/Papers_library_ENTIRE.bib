@article{Kida:2005bz,
author = {Kida, Hiroshi and Yoshida, Mitsuhiro and Hoshino, Shigenori and Inoue, Koji and Yano, Yukihiro and Yanagita, Masahiko and Kumagai, Toru and Osaki, Tadashi and Tachibana, Isao and Saeki, Yukihiko and Kawase, Ichiro},
title = {{Protective effect of IL-6 on alveolar epithelial cell death induced by hydrogen peroxide.}},
journal = {American journal of physiology. Lung cellular and molecular physiology},
year = {2005},
volume = {288},
number = {2},
pages = {L342--9},
month = feb,
affiliation = {National Hospital Organization Japan, Osaka Minami Medical Center, Kawachinagano, Osaka, Japan.},
doi = {10.1152/ajplung.00016.2004},
pmid = {15475383},
language = {English},
rating = {0},
date-added = {2012-05-04T19:20:30GMT+00:00},
date-modified = {2015-10-14T22:29:18GMT+00:00},
abstract = {The goal of this study was to examine whether IL-6 could directly protect lung resident cells, especially alveolar epithelial cells, from reactive oxygen species (ROS)-induced cell death. ROS induced IL-6 gene expression in organotypic lung slices of wild-type (WT) mice. ROS also induced IL-6 gene expression in mouse primary lung fibroblasts, dose dependently. The organotypic lung slices of WT were more resistant to ROS-induced DNA fragmentation than those of IL-6-deficient (IL-6-/-) mice. WT resistance against ROS was abrogated by treatment with anti-IL-6 antibody. TdT-mediated dUTP nick end labeling stain and electron microscopy revealed that DNA fragmented cells in the IL-6-/- slice included alveolar epithelial cells and endothelial cells. In vitro studies demonstrated that IL-6 reduced ROS-induced A549 alveolar epithelial cell death. Together, these data suggest that IL-6 played an antioxidant role in the lung by protecting lung resident cells, especially alveolar epithelial cells, from ROS-induced cell death.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=15475383&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2005/Kida/Am._J._Physiol._Lung_Cell_Mol._Physiol._2005_Kida.pdf},
file = {{Am._J._Physiol._Lung_Cell_Mol._Physiol._2005_Kida.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2005/Kida/Am._J._Physiol._Lung_Cell_Mol._Physiol._2005_Kida.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1152/ajplung.00016.2004}}
}

@article{NascimentoSilva:2011fx,
author = {Nascimento Silva, Juliana Romualdo and Camacho, Luiz Antonio B and Siqueira, Marilda M and Freire, Marcos de Silva and Castro, Yvone P and Maia, Maria de Lourdes S and Yamamura, Anna Maya Y and Martins, Reinaldo M and Leal, Maria de Luz F and {Collaborative Group for the Study of Yellow Fever Vaccines}},
title = {{Mutual interference on the immune response to yellow fever vaccine and a combined vaccine against measles, mumps and rubella.}},
journal = {Vaccine},
year = {2011},
volume = {29},
number = {37},
pages = {6327--6334},
month = aug,
affiliation = {Departamento de Epidemiologia, Escola Nacional de Sa{\'u}de P{\'u}blica, FIOCRUZ, Rua Leopoldo Bulh{\~o}es, 1480, sala 820, Manguinhos, Rio de Janeiro 21041-210, RJ, Brazil. julianarns@gmail.com},
doi = {10.1016/j.vaccine.2011.05.019},
pmid = {21640779},
language = {English},
rating = {0},
date-added = {2012-04-05T20:21:27GMT+00:00},
date-modified = {2015-10-14T22:29:18GMT+00:00},
abstract = {A randomized trial was conducted to assess the immunogenicity and reactogenicity of yellow fever vaccines (YFV) given either simultaneously in separate injections, or 30 days or more after a combined measles-mumps-rubella (MMR) vaccine. Volunteers were also randomized to YFV produced from 17DD and WHO-17D-213 substrains. The study group comprised 1769 healthy 12-month-old children brought to health care centers in Brasilia for routine vaccination. The reactogenicity was of the type and frequency expected for the vaccines and no severe adverse event was associated to either vaccine. Seroconversion and seropositivity 30 days or more after vaccination against yellow fever was similar across groups defined by YFV substrain. Subjects injected YFV and MMR simultaneously had lower seroconversion rates--90% for rubella, 70% for yellow fever and 61% for mumps--compared with those vaccinated 30 days apart--97% for rubella, 87% for yellow fever and 71% for mumps. Seroconversion rates for measles were higher than 98% in both comparison groups. Geometric mean titers for rubella and for yellow fever were approximately three times higher among those who got the vaccines 30 days apart. For measles and mumps antibodies GMTs were similar across groups. MMR's interference in immune response of YFV and YFV's interference in immune response of rubella and mumps components of MMR had never been reported before but are consistent with previous observations from other live vaccines. These results may affect the recommendations regarding primary vaccination with yellow fever vaccine and MMR.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=21640779&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/doi/10.1016/j.vaccine.2011.05.019}}
}

