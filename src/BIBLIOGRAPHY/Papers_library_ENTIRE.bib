@article{Marianneau:1998ux,
author = {Marianneau, P and Steffan, A M and Royer, C and Drouet, M T and Kirn, A and Deubel, V},
title = {{Differing infection patterns of dengue and yellow fever viruses in a human hepatoma cell line.}},
journal = {The Journal of Infectious Diseases},
year = {1998},
volume = {178},
number = {5},
pages = {1270--1278},
month = nov,
affiliation = {Unit{\'e} des Arbovirus et Virus des Fi{\'e}vres H{\'e}morragiques, Institut Pasteur, Paris, France.},
pmid = {9780246},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-06-04T14:45:12GMT+00:00},
date-modified = {2015-12-30T16:59:48GMT+00:00},
abstract = {Dengue (DEN) and yellow fever (YF) viruses are responsible for human diseases with symptoms ranging from mild fever to hepatitis and/or hemorrhages. Whereas DEN virus typically induces only limited foci of necrosis in the liver, YF virus infection is characterized by devastating lesions. In a human hepatoma cell line (HepG2), the kinetics of DEN and YF virus replication and release from the cells and the nature of host cell response to viral infection were compared. DEN virus infection was characterized by the early appearance of intracellular viral antigens, major ultrastructural cytopathic changes as early as 32 h after infection, extensive apoptotic cell death, and a low production of infectious particles. In contrast, YF virus grew exponentially to high titers and induced cytopathic changes only 72 h after infection. Differences between the infection processes of the two viruses observed in the hepatoma cell line may explain the different liver pathologies.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=9780246&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/1998/Marianneau/J_INFECT_DIS_1998_Marianneau.pdf},
file = {{J_INFECT_DIS_1998_Marianneau.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/1998/Marianneau/J_INFECT_DIS_1998_Marianneau.pdf:application/pdf}},
uri = {\url{papers3://publication/uuid/12730C3A-385E-4D4D-95EE-82B39DDD0417}}
}

