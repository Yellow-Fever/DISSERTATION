@article{Uchiyama:2008dz,
author = {Uchiyama, Yasushi and Yoshida, Hiroto and Koike, Nobuo and Hayakawa, Naohiko and Sugita, Atsuko and Nishimura, Takashi and Mihara, Masahiko},
title = {{Anti-IL-6 receptor antibody increases blood IL-6 level via the blockade of IL-6 clearance, but not via the induction of IL-6 production.}},
journal = {International immunopharmacology},
year = {2008},
volume = {8},
number = {11},
pages = {1595--1601},
month = nov,
affiliation = {Product Research Department, Chugai Pharmaceutical Co. Ltd., Japan.},
doi = {10.1016/j.intimp.2008.07.002},
pmid = {18664393},
language = {English},
rating = {0},
date-added = {2012-05-16T19:02:01GMT+00:00},
date-modified = {2015-10-14T22:29:54GMT+00:00},
abstract = {We explored the mechanism for the increase of blood IL-6 level after anti-IL-6 receptor (IL-6R) antibody injection. First, we examined whether anti-IL-6R antibody stimulates IL-6 production. Single injection of tocilizumab (anti-IL-6R antibody) in monkeys with collagen-induced arthritis (CIA) caused a marked increase in blood IL-6 and IL-6R levels, but did not increase IL-6 mRNA and IL-6R mRNA expression in liver, spleen, lymph nodes, synovium or whole blood 1, 3 and 7 days later. This suggests that tocilizumab did not induce IL-6 and IL-6R production. Second, we investigated whether anti-IL-6R antibody releases IL-6 from IL-6 complexes in the blood. When plasma from CIA monkeys was incubated with tocilizumab, the IL-6 concentration was not affected. Finally, we studied whether anti-IL-6R antibody affects the clearance of IL-6 from the blood. When MR16-1 (anti-mouse IL-6R antibody) was injected into IL-6-deficient mice continuously infused with human IL-6, blood human IL-6 levels significantly increased. These results suggest that the elevation of blood IL-6 after the administration of anti-IL-6R antibody is the result of inhibition of the clearance of IL-6 due to IL-6R blockade, and that it is not the result of induction of IL-6 production or release of IL-6 from complexes.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=18664393&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/doi/10.1016/j.intimp.2008.07.002}}
}

@article{Jennings:1994up,
author = {Jennings, A D and Gibson, C A and Miller, B R and Mathews, J H and Mitchell, C J and Roehrig, J T and Wood, D J and Taffs, F and Sil, B K and Whitby, S N},
title = {{Analysis of a yellow fever virus isolated from a fatal case of vaccine-associated human encephalitis.}},
journal = {The Journal of Infectious Diseases},
year = {1994},
volume = {169},
number = {3},
pages = {512--518},
month = mar,
affiliation = {Department of Pathology, University of Texas Medical Branch, Galveston.},
pmid = {7908925},
language = {English},
read = {Yes},
rating = {0},
date-added = {2013-08-21T15:53:06GMT+00:00},
date-modified = {2015-10-14T22:32:29GMT+00:00},
abstract = {The virulence of a yellow fever (YF) virus (P-16065) isolated from a fatal case of vaccine-associated viral encephalitis was investigated. P-16065 appeared identical to its parent vaccine virus (17D-204 USA, lot 6145) when examined with monoclonal antibodies except that YF wild type-specific MAb S24 recognized P-16065 but not 17D-204 USA 6145. Thus, a mutation of at least one epitope on the envelope (E) protein had occurred. Unlike 17D-204 USA 6145 and other 17D vaccine viruses, P-16065 was neuroinvasive and virulent for mice after intranasal inoculation, and neurovirulent for monkeys after intracerebral inoculation. The E protein of P-16065 differed from 17D-204 USA by two amino acids at positions 155 and 303. Changes at amino acid position 155 are found in other YF vaccine viruses that are not neurovirulent, and it is therefore postulated that the change at position 303 is involved in the alteration of the phenotype of P-16065 and may be important for virulence of YF virus.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=7908925&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/1994/Jennings/J_INFECT_DIS_1994_Jennings.pdf},
file = {{J_INFECT_DIS_1994_Jennings.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/1994/Jennings/J_INFECT_DIS_1994_Jennings.pdf:application/pdf}},
uri = {\url{papers3://publication/uuid/97935B02-2040-4857-8BA5-D1AFCF3326E9}}
}

