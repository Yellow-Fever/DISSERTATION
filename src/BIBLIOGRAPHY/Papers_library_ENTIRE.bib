pages = {75--80},
month = jan,
affiliation = {Fundacao Oswaldo Cruz, Instituto de Tecnologia em Imunobiologicos, Departamento de Bioquimica e Biologia Molecular, Rio de Janeiro, Brazil.},
pmid = {7856829},
language = {English},
rating = {0},
