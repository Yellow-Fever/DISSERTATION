@article{Barrett:2004el,
author = {Barrett, Alan D T},
title = {{Current status of the Arilvax; yellow fever vaccine.}},
journal = {Expert Review of Vaccines},
year = {2004},
volume = {3},
number = {4},
pages = {413--420},
month = aug,
affiliation = {Department of Pathology and Sealy Center for Vaccine Development, University of Texas Medical Branch, Galveston, TX 77555-0609, USA. abarrett@utmb.edu},
doi = {10.1586/14760584.3.4.413},
pmid = {15270646},
language = {English},
read = {Yes},
rating = {0},
date-added = {2015-05-14T16:20:33GMT+00:00},
date-modified = {2015-10-14T22:29:52GMT+00:00},
abstract = {Yellow fever is a viral hemorrhagic fever that involves dysfunction of the liver and kidneys. There is no antiviral therapy available and vaccination is a major strategy in the control of this important public health problem. Yellow fever vaccine is a live attenuated vaccine, strain 17D, which is very safe and efficacious and induces long-term protective immunity in vaccinees. The vaccine is produced by six manufacturers worldwide, including Arilvax by Chiron vaccines (CA, USA) that is marketed in at least ten countries. Acambis (MA, USA) have acquired the rights to sell and market Arilvax in the USA, and have undertaken three clinical trials to obtain data for a Biological License Application that should proceed in 2005.},
url = {http://informahealthcare.com/doi/abs/10.1586/14760584.3.4.413},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/A5/A5C29FD7-38A3-46A0-84EA-E4BE63DEA7BA.pdf},
file = {{A5C29FD7-38A3-46A0-84EA-E4BE63DEA7BA.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/A5/A5C29FD7-38A3-46A0-84EA-E4BE63DEA7BA.pdf:application/pdf;A5C29FD7-38A3-46A0-84EA-E4BE63DEA7BA.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/A5/A5C29FD7-38A3-46A0-84EA-E4BE63DEA7BA.pdf:application/pdf}},
