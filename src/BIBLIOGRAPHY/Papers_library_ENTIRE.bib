@article{Hirano:2012kj,
author = {Hirano, Hirofumi and Yoshioka, Takako and Yunoue, Shunji and Fujio, Shingo and Yonezawa, Hajime and Niiro, Tadaaki and Habu, Mika and Oyoshi, Tatsuki and Sugata, Sei and Kamezawa, Takashi and Arimura, Hiroshi and Hanaya, Ryosuke and Tokimura, Hiroshi and Tokudome, Mai and Arita, Kazunori},
title = {{TLR4, IL-6, IL-18, MyD88 and HMGB1 are highly expressed in intracranial inflammatory lesions and the IgG4/IgG ratio correlates with TLR4 and IL-6.}},
journal = {Neuropathology : official journal of the Japanese Society of Neuropathology},
year = {2012},
month = mar,
affiliation = {Departments of Neurosurgery Molecular and Cellular Pathology, Field of Oncology Cardiovascular, Respiratory and Metabolic Medicine, Graduate School of Medical and Dental Sciences, Kagoshima University, Kagoshima, Japan.},
doi = {10.1111/j.1440-1789.2012.01310.x},
pmid = {22414145},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-04-25T20:44:54GMT+00:00},
date-modified = {2015-10-14T22:29:37GMT+00:00},
abstract = {We determined distribution of plasma cells and IgG4/IgG index and factors associated with the index in intracranial inflammatory lesions. Specimens of nine patients were analyzed immunohistochemically using antibodies against CD45, CD68, CD3, CD4, CD8, CD20, CD138, lambda chain, kappa chain, IgG, IgG4, IL-1$\alpha$, IL-6, IL-18, toll-like receptor (TLR) 2, TLR4, high-mobility group box 1 (HMGB1), tumor necrosis factor-alpha (TNF-$\alpha$), myeloid differentiation factor 88 (MyD88), and anaplastic lymphoma kinase (ALK). The relationship between all the factors was assessed using Spearman's rank correlation coefficient ($\rho$). Negative ALK staining was observed in all the patients. Plasma cells were detected in eight patients with varying degrees. The highest number of neutrophils, but no plasma cells, was observed in a patient with the shortest history of inflammation. IgG4/IgG index was independent of the number of plasma cells. The index was relatively highly correlated with IL-6 ($\rho$ = 0.7271) and TLR4 expression ($\rho$ = 0.7246). IL-6 expression was highly correlated with TLR4 expression ($\rho$ = 0.8042). IL-18 was maximally expressed in all the patients. TLR4 expression was strong, but TRL2 expression was weak. Positive HMGB1 staining was observed in all the patients, predominantly in the nuclei, but also in the cytoplasm in four patients. The cytoplasmic expression strongly correlated with IL-1$\alpha$ expression ($\rho$ = 0.9583). The cytoplasmic colocalization of HMGB1 and IL-1$\alpha$ was histologically confirmed in cells with collapsing nuclei by the double-staining method. The IgG4/IgG indexes varied case by case. IL-6 and TLR4 expressions may influence IgG4/IgG index. The nuclei of cells with both IL-1$\alpha$ and HMGB1 expressions in the cytoplasm collapse in the cell death stage. The cooperative high expression of TLR4, IL-6, IL-18, MyD88 and HMGB1 suggest their critical roles in the inflammation circuit.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=22414145&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2012/Hirano/Neuropathology_2012_Hirano.pdf},
file = {{Neuropathology_2012_Hirano.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2012/Hirano/Neuropathology_2012_Hirano.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1111/j.1440-1789.2012.01310.x}}
}

