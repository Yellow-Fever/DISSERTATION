@article{Eno:2012fb,
author = {Eno, Colins O and Eckenrode, Emily F and Olberding, Kristen E and Zhao, Guoping and White, Carl and Li, Chi},
title = {{Distinct Roles of Mitochondria- and ER-localized Bcl-xL in Apoptosis Resistance and Ca2+ Homeostasis.}},
journal = {Molecular biology of the cell},
year = {2012},
month = may,
affiliation = {*Molecular Targets Program, James Graham Brown Cancer Center, University of Louisville, Louisville, KY 40202 {\dag}Departments of Medicine, Pharmacology and Toxicology, University of Louisville, Louisville, KY 40202 {\ddag}Physiology and Biophysics, Rosalind Franklin University of Medicine and Science, North Chicago, IL 60064.},
doi = {10.1091/mbc.E12-02-0090},
pmid = {22573883},
language = {English},
rating = {0},
date-added = {2012-05-15T21:27:32GMT+00:00},
date-modified = {2015-10-14T22:29:52GMT+00:00},
abstract = {Bcl-2 proteins are major regulators of cellular responses to intrinsic and extrinsic apoptotic stimuli. Among them, overexpression of the anti-apoptotic protein Bcl-x(L) modulates intracellular Ca(2+) homeostasis and organelle-specific apoptotic signaling pathways. However, the specific activities of Bcl-x(L) at mitochondria and the endoplasmic reticulum (ER) have not been fully defined. To further explore this, we generated mouse embryonic fibroblast (MEF) cell lines deficient in Bcl-x(L) expression (Bcl-x-KO). Deficiency in Bcl-x(L) expression did not induce compensatory changes in the expression of other Bcl-2 proteins, and Bcl-x-KO MEF cells showed increased sensitivity to various apoptotic stimuli compared with wild-type MEF cells. Targeting Bcl-x(L) at mitochondria but not at the ER restored apoptosis protection in Bcl-x-KO MEF cells to the degree observed in wild-type MEF cells. However, expression of ER-targeted Bcl-x(L) but not mitochondrially targeted Bcl-x(L) was required to restore Ca(2+) homeostasis in Bcl-x-KO MEF cells. Importantly, ER-targeted Bcl-x(L) was able to protect cells against death stimuli in the presence of endogenous Bcl-x(L). These data indicate that mitochondrial Bcl-x(L) can regulate apoptosis independently of ER Bcl-x(L) and that when localized exclusively at the ER, Bcl-x(L) impinges on Ca(2+) homeostasis but does not affect apoptosis unless Bcl-x(L) is present in additional cellular compartments.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=22573883&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/doi/10.1091/mbc.E12-02-0090}}
}

