language = {English},
rating = {0},
date-added = {2012-05-04T19:14:40GMT+00:00},
date-modified = {2015-10-14T22:29:46GMT+00:00},
abstract = {Interleukin-6 (IL-6) is a pleiotropic cytokine involved in the regulation of proliferation and differentiation of hematopoietic cells and in the pathogenesis of many diseases, including multiple myeloma. This study pursues a way to interfere with IL-6 pathway in an attempt to modulate its biological activity. Here we describe the rational design and biological evaluation of peptides able to antagonize the murine IL-6 activity by interfering with IL-6 Receptor alpha in 7TD1 cells, a IL-6-dependent B-cell line. Of the peptide tested, only Guess 4a is capable of interfering with IL-6 transducing pathway, therefore inducing growth arrest and apoptosis of 7TD1 cells.},
