@article{Stim:1970ur,
author = {Stim, T B},
title = {{Dengue virus plaque development in simian cell systems. I. Factors influencing virus adsorption and variables in the agar overlay medium.}},
journal = {Applied microbiology},
year = {1970},
volume = {19},
number = {5},
pages = {751--756},
month = may,
