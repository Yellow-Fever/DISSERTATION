journal = {Journal of General Virology},
year = {1997},
volume = {78 ( Pt 6)},
pages = {1349--1352},
month = jun,
affiliation = {Center for Tropical Diseases, University of Texas Medical Branch, Galveston 77555-0605, USA.},
