@article{Ni:2000un,
author = {Ni, H and Ryman, K D and Wang, H and Saeed, M F and Hull, R and Wood, D and Minor, P D and Watowich, S J and Barrett, A D},
title = {{Interaction of yellow fever virus French neurotropic vaccine strain with monkey brain: characterization of monkey brain membrane receptor escape variants.}},
journal = {Journal of Virology},
year = {2000},
volume = {74},
number = {6},
pages = {2903--2906},
month = mar,
affiliation = {Department of Pathology, University of Texas Medical Branch, Galveston, Texas 77555-0609, USA.},
pmid = {10684309},
pmcid = {PMC111783},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-04-24T19:36:51GMT+00:00},
date-modified = {2015-10-26T17:22:40GMT+00:00},
abstract = {Binding of yellow fever virus wild-type strains Asibi and French viscerotropic virus and vaccine strains 17D and FNV to monkey brain and monkey liver cell membrane receptor preparations (MRPs) was investigated. Only FNV bound to monkey brain MRPs, while French viscerotropic virus, Asibi, and FNV all bound to monkey liver MRPs. Four monkey brain and two mouse brain MRP escape (MRP(R)) variants of FNV were selected at pH 7.6 and 6.0. Three monkey brain MRP(R) variants selected at pH 7.6 each had only one amino acid substitution in the envelope (E) protein in domain II (E-237, E-260, or E274) and were significantly attenuated in mice following intracerebral inoculation. Two of the variants were tested in monkeys and retained parental neurotropism following intracerebral inoculation at the dose tested. We speculate that this region of domain II is involved in binding of FNV E protein to monkey brain and is, in part, responsible for the enhanced neurotropism of FNV for monkeys. A monkey brain MRP(R) variant selected at pH 6.0 and two mouse brain MRP(R) variants selected at pH 7.6 were less attenuated in mice, and each had an amino acid substitution in the transmembrane region of the E protein (E-457 or E-458).},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=10684309&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/uuid/B9F53EBC-038B-4A66-AD39-24D7E96CD8B8}}
}

