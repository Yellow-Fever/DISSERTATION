@article{Nassar:1995um,
author = {Nassar, E da S and Chamelet, E L and Coimbra, T L and de Souza, L T and Suzuki, A and Ferreira, I B and da Silva, M V and Rocco, I M and Travassos da Rosa, A P},
title = {{Jungle yellow fever: clinical and laboratorial studies emphasizing viremia on a human case.}},
journal = {Revista do Instituto de Medicina Tropical de S{\~a}o Paulo},
year = {1995},
volume = {37},
number = {4},
pages = {337--341},
month = jul,
affiliation = {Instituto Adolfo Lutz, S{\~a}o Paulo, Brasil.},
pmid = {8599063},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-06-05T15:09:40GMT+00:00},
date-modified = {2015-10-14T22:28:33GMT+00:00},
abstract = {The authors report the clinical, laboratorial and epidemiological aspects of a human case of jungle yellow fever. The patient suffered from fever, chills, sweating, headaches, backaches, myalgia, epigastric pains, nausea, vomiting, diarrhea and prostration. He was unvaccinated and had been working in areas where cases of jungle yellow fever had been confirmed. Investigations concerning the yellow fever virus were performed. Blood samples were collected on several days in the course of the illness. Three of these samples (those obtained on days 5, 7 and 10) were inoculated into suckling mice in attempt to isolate virus and to titrate the viremia level. Serological surveys were carried out by using the IgM Antibodies Capture Enzyme Linked Immunosorbent Assay (MAC-ELISA), Complement Fixation (CF), Hemagglutination Inhibition (HI) and Neutralization (N) tests. The yellow fever virus, recovered from the two first samples and the virus titration, showed high level of viremia. After that, specific antibodies appeared in all samples. The interval between the end of the viremia and the appearance of the antibodies was associated with the worsening of clinical symptoms, including bleeding of the mucous membrane. One must be aware of the risk of having a urban epidemics in areas where Aedes aegypti is found in high infestation indexes.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=8599063&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/1995/Nassar/Rev._Inst._Med._Trop._Sao_Paulo_1995_Nassar.pdf},
file = {{Rev._Inst._Med._Trop._Sao_Paulo_1995_Nassar.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/1995/Nassar/Rev._Inst._Med._Trop._Sao_Paulo_1995_Nassar.pdf:application/pdf}},
uri = {\url{papers3://publication/uuid/383321C9-395F-4019-8AF4-DD3D21A52185}}
}

