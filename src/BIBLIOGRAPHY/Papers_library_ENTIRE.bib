title = {{Class III PI3K Vps34 plays an essential role in autophagy and in heart and liver function.}},
journal = {Proceedings of the National Academy of Sciences},
year = {2012},
volume = {109},
number = {6},
pages = {2003--2008},
month = feb,
affiliation = {Department of Molecular Genetics and Microbiology, Stony Brook University, Stony Brook, NY 11794, USA.},
doi = {10.1073/pnas.1112848109},
pmid = {22308354},
pmcid = {PMC3277541},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-05-04T19:41:29GMT+00:00},
date-modified = {2015-10-14T22:29:39GMT+00:00},
abstract = {A critical regulator of autophagy is the Class III PI3K Vps34 (also called PIK3C3). Although Vps34 is known to play an essential role in autophagy in yeast, its role in mammals remains elusive. To elucidate the physiological function of Vps34 and to determine its precise role in autophagy, we have generated Vps34(f/f) mice, in which expression of Cre recombinase results in a deletion of exon 4 of Vps34 and a frame shift causing a deletion of 755 of the 887 amino acids of Vps34. Acute ablation of Vps34 in MEFs upon adenoviral Cre infection results in a diminishment of localized generation of phosphatidylinositol 3-phosphate and blockade of both endocytic and autophagic degradation. Starvation-induced autophagosome formation is blocked in both Vps34-null MEFs and liver. Liver-specific Albumin-Cre;Vps34(f/f) mice developed hepatomegaly and hepatic steatosis, and impaired protein turnover. Ablation of Vps34 in the heart of muscle creatine kinase-Cre;Vps34(f/f) mice led to cardiomegaly and decreased contractility. In addition, while amino acid-stimulated mTOR activation was suppressed in the absence of Vps34, the steady-state level of mTOR signaling was not affected in Vps34-null MEFs, liver, or cardiomyocytes. Taken together, our results indicate that Vps34 plays an essential role in regulating functional autophagy and is indispensable for normal liver and heart function.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=22308354&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2012/Jaber/Proceedings_of_the_National_Academy_of_Sciences_2012_Jaber.pdf},
file = {{Proceedings_of_the_National_Academy_of_Sciences_2012_Jaber.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2012/Jaber/Proceedings_of_the_National_Academy_of_Sciences_2012_Jaber.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1073/pnas.1112848109}}
}

