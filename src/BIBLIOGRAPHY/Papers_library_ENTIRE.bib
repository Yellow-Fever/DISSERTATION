@article{Graziano:2002uv,
author = {Graziano, Kristin L and Tempest, Bruce},
title = {{Hantavirus pulmonary syndrome: a zebra worth knowing.}},
journal = {American family physician},
year = {2002},
volume = {66},
number = {6},
pages = {1015--1020},
month = sep,
affiliation = {Tuba City Indian Medical Center, Navajo Area Indian Health Service, Arizona 86045, USA. doc-gratz@yahoo.com},
pmid = {12358213},
language = {English},
rating = {0},
date-added = {2013-12-13T20:50:26GMT+00:00},
date-modified = {2015-10-14T22:29:33GMT+00:00},
abstract = {Hantavirus pulmonary syndrome (HPS) is a severe cardiopulmonary illness most often caused by the Sin Nombre virus, which is transmitted to humans by inhalation of aerosolized particles of rodent excreta or direct rodent contact. Although HPS is more common in the western United States, cases have been identified in 31 states. The illness begins as a nonspecific febrile prodrome, sharing many of its initial symptoms with other more common viral infections. Patients then quickly develop noncardiogenic pulmonary edema, respiratory failure, and shock. Characteristic laboratory findings include thrombocytopenia, a left-shifted leukocytosis, hemoconcentration, and presence of immunoblasts. The overall case fatality rate of HPS is approximately 40 percent. Diagnosis is confirmed by serologic identification of IgM and IgG antibodies to Sin Nombre virus. There is no specific therapy, but early recognition of HPS during the prodromal phase can expedite initiating cardiopulmonary support in an intensive care unit, which is associated with improved survival rates. Prevention of HPS involves avoiding contact with rodents and rodent habitats.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=12358213&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2002/Graziano/Am_Fam_Physician_2002_Graziano.pdf},
file = {{Am_Fam_Physician_2002_Graziano.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2002/Graziano/Am_Fam_Physician_2002_Graziano.pdf:application/pdf}},
uri = {\url{papers3://publication/uuid/17D67609-6513-4A06-B55C-D7F8651BD923}}
}

@article{Coffey:2011ba,
author = {Coffey, Lark L and Vignuzzi, Marco},
title = {{Host alternation of chikungunya virus increases fitness while restricting population diversity and adaptability to novel selective pressures.}},
journal = {Journal of Virology},
year = {2011},
volume = {85},
number = {2},
pages = {1025--1035},
month = jan,
affiliation = {Institut Pasteur, Viral Populations and Pathogenesis, CNRS URA 3015, 28 rue du Dr Roux, 75724 Paris Cedex 15, France.},
doi = {10.1128/JVI.01918-10},
pmid = {21047966},
pmcid = {PMC3020036},
language = {English},
read = {Yes},
rating = {0},
date-added = {2012-04-03T16:35:16GMT+00:00},
date-modified = {2015-10-14T22:29:33GMT+00:00},
abstract = {The mechanisms by which RNA arboviruses, including chikungunya virus (CHIKV), evolve and maintain the ability to infect vertebrate and invertebrate hosts are poorly understood. To understand how host specificity shapes arbovirus populations, we studied CHIKV populations passaged alternately between invertebrate and vertebrate cells (invertebrate $\leftrightarrow$ vertebrate) to simulate natural alternation and contrasted the results with those for populations that were artificially released from cycling by passage in single cell types. These CHIKV populations were characterized by measuring genetic diversity, changes in fitness, and adaptability to novel selective pressures. The greatest fitness increases were observed in alternately passaged CHIKV, without drastic changes in population diversity. The greatest increases in genetic diversity were observed after serial passage and correlated with greater adaptability. These results suggest an evolutionary trade-off between maintaining fitness for invertebrate $\leftrightarrow$ vertebrate cell cycling, where maximum adaptability is possible only via enhanced population diversity and extensive exploration of sequence space.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=21047966&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2011/Coffey/Journal_of_Virology_2011_Coffey.pdf},
file = {{Journal_of_Virology_2011_Coffey.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2011/Coffey/Journal_of_Virology_2011_Coffey.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.1128/JVI.01918-10}}
}

