@article{McGee:2008ff,
author = {McGee, Charles E and Lewis, Mark G and Claire, Marisa St and Wagner, Wendeline and Lang, Jean and Guy, Bruno and Tsetsarkin, Konstantin and Higgs, Stephen and Decelle, Thierry},
title = {{Recombinant chimeric virus with wild-type dengue 4 virus premembrane and envelope and virulent yellow fever virus Asibi backbone sequences is dramatically attenuated in nonhuman primates.}},
journal = {The Journal of Infectious Diseases},
year = {2008},
volume = {197},
number = {5},
pages = {693--697},
month = mar,
affiliation = {Department of Pathology, University of Texas Medical Branch, Galveston, TX 77555-0609, USA. cemcgee@utmb.edu},
