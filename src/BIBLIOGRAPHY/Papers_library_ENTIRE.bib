@article{Komarova:2013by,
author = {Komarova, Anastassia V and Combredet, Chantal and Sismeiro, Odile and Dillies, Marie-Agn{\`e}s and Jagla, Bernd and Sanchez David, Raul Yusef and Vabret, Nicolas and Copp{\'e}e, Jean-Yves and Vidalain, Pierre-Olivier and Tangy, Fr{\'e}d{\'e}ric},
title = {{Identification of RNA partners of viral proteins in infected cells.}},
journal = {RNA biology},
year = {2013},
volume = {10},
number = {6},
pages = {944--956},
month = jun,
affiliation = {Unit{\'e} de G{\'e}nomique virale et Vaccination, Institut Pasteur, CNRS URA-3015, Paris, France.},
doi = {10.4161/rna.24453},
pmid = {23595062},
pmcid = {PMC4111734},
language = {English},
read = {Yes},
rating = {0},
date-added = {2015-01-12T16:42:16GMT+00:00},
date-modified = {2015-10-14T22:29:15GMT+00:00},
abstract = {RNA viruses exhibit small-sized genomes encoding few proteins, but still establish complex networks of protein-protein and RNA-protein interactions within a cell to achieve efficient replication and spreading. Deciphering these interactions is essential to reach a comprehensive understanding of the viral infection process. To study RNA-protein complexes directly in infected cells, we developed a new approach based on recombinant viruses expressing tagged viral proteins that were purified together with their specific RNA partners. High-throughput sequencing was then used to identify these RNA molecules. As a proof of principle, this method was applied to measles virus nucleoprotein (MV-N). It revealed that in addition to full-length genomes, MV-N specifically interacted with a unique population of 5' copy-back defective interfering RNA genomes that we characterized. Such RNA molecules were able to induce strong activation of interferon-stimulated response element promoter preferentially via the cytoplasmic pattern recognition receptor RIG-I protein, demonstrating their biological functionality. Thus, this method provides a new platform to explore biologically active RNA-protein networks that viruses establish within infected cells.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=23595062&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Articles/2013/Komarova/RNA_Biol_2013_Komarova.pdf},
file = {{RNA_Biol_2013_Komarova.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Articles/2013/Komarova/RNA_Biol_2013_Komarova.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.4161/rna.24453}}
}

