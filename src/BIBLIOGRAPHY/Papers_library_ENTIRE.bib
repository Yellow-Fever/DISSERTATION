@article{Dumre:2013iu,
author = {Dumre, Shyam P and Shakya, Geeta and Na-Bangchang, Kesara and Eursitthichai, Veerachai and Rudi Grams, Hans and Upreti, Senendra R and Ghimire, Prakash and KC, Khagendra and Nisalak, Ananda and Gibbons, Robert V and Fernandez, Stefan},
title = {{Dengue virus and Japanese encephalitis virus epidemiological shifts in Nepal: a case of opposing trends.}},
journal = {The American Journal of Tropical Medicine and Hygiene},
year = {2013},
volume = {88},
number = {4},
pages = {677--680},
month = apr,
affiliation = {Faculty of Allied Health Sciences, Thammasat University, Pathumthani, Thailand. shyamprad@hotmail.com},
doi = {10.4269/ajtmh.12-0436},
pmid = {23419366},
pmcid = {PMC3617851},
language = {English},
rating = {0},
date-added = {2015-09-08T16:58:23GMT+00:00},
date-modified = {2015-10-14T22:29:59GMT+00:00},
abstract = {We report on the changing epidemiology of two important flaviviruses in Nepal: Japanese encephalitis (JE) and dengue viruses. Morbidity and mortality in Nepal is in the thousands since JE was introduced in 1978. Nepal launched an extensive laboratory-based JE surveillance in 2004. Nepal experienced a remarkable reduction in disease burden after mass immunizations from 2005 to 2010, when 2,040 JE infections and 205 JE-related deaths were confirmed. With its emergence in 2006, dengue has become a significant challenge in the country, highlighted by a sudden outbreak in 2010 that resulted in 359 confirmed dengue infections. Currently, both viruses cocirculate in Nepal. Here, we document the remarkable expansion of dengue in Nepal, which urgently requires national surveillance to refine the burden and make recommendations regarding control and prevention programs. We believe that the use of existing JE surveillance network for integrated dengue surveillance may represent the most appropriate alternative.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=23419366&retmode=ref&cmd=prlinks},
local-url = {file://localhost/Users/andrewbeck/Dropbox/Library.papers3/Files/8F/8FC1B833-80A1-470D-AF67-4535C63BD063.pdf},
file = {{8FC1B833-80A1-470D-AF67-4535C63BD063.pdf:/Users/andrewbeck/Dropbox/Library.papers3/Files/8F/8FC1B833-80A1-470D-AF67-4535C63BD063.pdf:application/pdf}},
uri = {\url{papers3://publication/doi/10.4269/ajtmh.12-0436}}
}

