affiliation = {Unit{\'e} des arbovirus et virus des fi{\`e}vres h{\'e}morragiques, Institut Pasteur, Paris, France.},
pmid = {11000957},
language = {fre},
rating = {0},
date-added = {2012-06-04T14:45:12GMT+00:00},
date-modified = {2015-12-30T16:59:48GMT+00:00},
abstract = {Yellow fever is an arthropod-borne disease with symptoms ranging from mild fever to acute hepatonephritis, hemorrhages and shock often fatal. The pathophysiology of severe yellow fever in humans and in monkeys susceptible to the virus is largely unknown. Yellow fever virus replicates in K{\"u}pffer cells and in hepatocytes in the liver. The degree of severity in yellow fever disease is linked to different factors related to virus virulence and to host susceptibility. A better knowledge of the complex interactions between the virus and the host is requested before initiating new actions in prophylaxy and therapy against yellow fever.},
url = {http://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi?dbfrom=pubmed&id=11000957&retmode=ref&cmd=prlinks},
uri = {\url{papers3://publication/uuid/AC8CBA2B-BDD7-4F87-82DE-C6EC488CF0DB}}
}

